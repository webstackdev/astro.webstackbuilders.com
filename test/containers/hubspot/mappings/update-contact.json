{
  "request": {
    "method": "PATCH",
    "urlPathPattern": "/crm/v3/objects/contacts/.*",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      }
    }
  },
  "response": {
    "status": 200,
    "body": "{\n  \"id\": \"{{request.pathSegments.[4]}}\",\n  \"properties\": {},\n  \"createdAt\": \"{{now format='yyyy-MM-dd\\'T\\'HH:mm:ss.SSSXXX'}}\",\n  \"updatedAt\": \"{{now format='yyyy-MM-dd\\'T\\'HH:mm:ss.SSSXXX'}}\",\n  \"archived\": false\n}",
    "headers": {
      "Content-Type": "application/json",
      "X-Mock-Service": "hubspot"
    },
    "transformers": ["response-template"]
  }
}
