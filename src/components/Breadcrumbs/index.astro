---
import { generateBreadcrumbs } from '@components/Breadcrumbs/server'

export interface Props {
  /** The current URL path */
  path: string
  /** Optional page title override */
  pageTitle?: string
}

const { path, pageTitle } = Astro.props
// Astro.site is only available when the project is configured with a `site` value.
// In unit tests (Astro Container API), that config may be unavailable, so fall back to the request URL origin.
const site = Astro.site ?? (Astro.url ? new URL(Astro.url.origin) : undefined)

// Don't show breadcrumbs on home page
if (path === '/' || path === '') {
  return null
}

const breadcrumbs = generateBreadcrumbs(path, pageTitle)
const breadcrumbSchema =
  site && breadcrumbs.length > 1
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.label,
          item: new URL(item.href, site).href,
        })),
      })
    : null
---

{
  breadcrumbs.length > 1 && (
    <div class="min-w-0 ml-2">
      <nav aria-label="Breadcrumbs" class="breadcrumbs">
        <ol class="flex flex-wrap items-center text-sm text-content">
          {breadcrumbs.map((item, i) => (
            <li class="flex items-center">
              {i > 0 && (
                <span class="w-6 h-px border-t-2 border-dashed border-page-inverse" />
              )}
              {item.isCurrentPage ? (
                <span aria-current="page" class="rounded px-2 py-1 text-xs text-content-inverse bg-page-inverse">
                  {item.label}
                </span>
              ) : (
                <a href={item.href} class="rounded px-2 py-1 text-xs text-page-inverse no-underline transition-colors bg-page-base border border-page-inverse hover:bg-secondary hover:text-content-inverse focus-visible:text-content-inverse focus-visible:bg-secondary">
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ol>

        {breadcrumbSchema && (
          <script is:inline type="application/ld+json" set:html={breadcrumbSchema} />
        )}
      </nav>
    </div>
  )
}
