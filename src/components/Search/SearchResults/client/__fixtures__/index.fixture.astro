---
import SearchResults from '@components/Search/SearchResults/index.astro'

const {
	query = 'typescript',
	limit,
	showSearchBar,
	hideSearchEmptyState,
} = Astro.props
---

<SearchResults
	query={query}
	limit={limit}
	showSearchBar={showSearchBar}
	hideSearchEmptyState={hideSearchEmptyState}
/>
