---
import Icon from '@components/Icon/index.astro'

export type Props = {
  href: string
}

const { href } = Astro.props
---

<a
  class="group transition-colors no-underline hover:no-underline focus-visible:no-underline"
  aria-label="Link to this section"
  href={href}
  tabindex="-1"
>
  <span
    class="inline-block ml-[0.2rem] opacity-0 -translate-x-1 transition-opacity duration-200 ease-in-out [h1:hover_&]:opacity-100 [h2:hover_&]:opacity-100 [h3:hover_&]:opacity-100 [h4:hover_&]:opacity-100 [h5:hover_&]:opacity-100 [h6:hover_&]:opacity-100 group-focus-visible:opacity-100"
    aria-hidden="true"
  >
    <Icon icon="link" size={6} color="page-inverse" classes="" />
  </span>
</a>
