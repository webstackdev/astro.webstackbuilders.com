---
import contactData from '@content/contact.json'
import HeadingAnchor from '@components/Layout/HeadingAnchor/index.astro'
import Icon from '@components/Icon/index.astro'
import List from '@components/List/index.astro'

export type Props = {
  content: {
    header: {
      title: string
      description: string
    }
    nav: {
      title: string
      links: {
        consentPreferencesText: string
        myDataText: string
      }
      items: {
        label: string
        href: string
      }[]
    }
    collection: {
      title: string
      cards: {
        title: string
        description: string
        listItems: {
          text: string
          icon: string
          color: string
        }[]
        listIconSize?: number
        trailer?: string
      }[]
    }
    usage: {
      title: string
      description: string
      listItems: {
        title: string
        description: string
        icon: string
        color: string
        background: string
      }[]
      listIconSize?: number
    }
    sharing: {
      title: string
      subtitle: string
      description: string
      listItems: {
        text: string
        color: string
      }[]
    }
    security: {
      title: string
      description: string
      cards: {
        lead: string
        text: string
        icon: string
        color: string
        background: string
      }[]
    }
    rights: {
      title: string
      description: string
      cards: {
        lead: string
        text: string
        icon: string
        color: string
      }[]
    }
    cookies: {
      title: string
      description: string
      subtitle: string
      listItems: {
        lead: string
        text: string
        color: string
      }[]
    }
    storage: {
      title: string
      description: string
      subtitle: string
      listItems: {
        lead: string
        text: string | string[]
        color: string
      }[]
      trailer: string
    }
    monitoring: {
      title: string
      description: string
      list1: {
        lead: string
        listItems: {
          heading: string
          text: string
        }[]
      }
      list2: {
        lead: string
        listItems: {
          text: string
          color?: string
        }[]
      }
      close: {
        heading: string
        text: string
      }
    }
    contact: {
      title: string
      description: string
      card1: {
        lead: string
        text: string
        link: string
      },
      card2: {
        lead: string
        text: string
      }
      card3: {
        lead: string
        text: string
      }
    }
    changes: {
      title: string
      description: string
    }
  }
}

type NavItem = Props['content']['nav']['items'][number]
type CollectionCard = Props['content']['collection']['cards'][number]

const { content }: Props = Astro.props

const navItems: Array<NavItem & { showSeparator: boolean }> = []

for (const [index, item] of content.nav.items.entries()) {
  navItems.push({
    ...item,
    showSeparator: index < content.nav.items.length - 1,
  })
}
---

<div class="mx-auto max-w-full px-4 py-2 sm:px-6 md:py-4 lg:px-8">
  <nav aria-label="Privacy policy sections" class="bg-content-active rounded-xl p-6 mb-8">
    <div class="mb-3 flex flex-col items-start gap-3 pl-2 md:flex-row md:items-center md:justify-between">
      <p class="text-md font-semibold text-content-inverse mb-0">{content.nav.title}</p>
      <div class="flex w-full flex-wrap items-center justify-center gap-3 md:w-auto md:flex-nowrap md:justify-end">
        <a
          href="/consent"
          class="text-content-inverse text-center underline decoration-content-inverse decoration-dotted underline-offset-4 hover:text-content-offset hover:decoration-content-offset focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 md:mr-8"
        >
          {content.nav.links.consentPreferencesText}
        </a>
        <a
          href="/privacy/my-data"
          class="text-content-inverse text-center underline decoration-content-inverse decoration-dotted underline-offset-4 hover:text-content-offset hover:decoration-content-offset focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 md:mr-16"
        >
          {content.nav.links.myDataText}
        </a>
      </div>
    </div>
    <div class="flex flex-wrap items-center gap-y-2 md:gap-x-2 text-md md:ml-6">
      {
        navItems.map(({ href, label, showSeparator }) => (
          <>
            <a
              href={href}
              class="text-content-inverse hover:text-content-offset transition-colors no-underline"
            >
              {label}
            </a>
            {showSeparator && (
              <span class="mx-2 text-content-inverse" aria-hidden="true">·</span>
            )}
          </>
        ))
      }
    </div>
  </nav>

  <div class="prose prose-lg w-full max-w-none min-w-0 wrap-break-word text-content">
    <section class="mb-12" aria-labelledby="privacy-information-we-collect-title">
      <h2 class="text-page-inverse mb-0 sm:mb-6 mt-0 sm:mt-12" id="privacy-information-we-collect-title">
        {content.collection.title}
        <HeadingAnchor href={"#privacy-information-we-collect-title"} />
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {
          content.collection.cards.map((card: CollectionCard) => (
            <div class="text-content-active bg-page-offset rounded-xl px-8 sm:pt-8 pb-4 shadow-md">
              <h3 class="text-page-inverse mb-4 mt-0">
                {card.title}
              </h3>
              <p class="mb-2">
                {card.description}
              </p>
              <List
                variant="plain-icon-list"
                items={card.listItems}
              />
              {card.trailer && (
                <p class="mt-6 mb-0 text-sm italic text-center text-content-offset">
                  {card.trailer}
                </p>
              )}
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-how-we-use-title">
      <h2 class="text-page-inverse mb-6" id="privacy-how-we-use-title">
        {content.usage.title}
        <HeadingAnchor href={"#privacy-how-we-use-title"} />
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {
          content.usage.listItems.map((item) => (
            <div class="text-content-active bg-primary-inverse rounded-xl px-8 pt-8 pb-4 shadow-md">
              <div class="flex items-center mb-4">
                <div
                  class:list={["w-12 h-12 rounded-lg flex items-center justify-center mr-4", item.background]}
                >
                  <Icon
                    icon={item.icon}
                    color={item.color}
                    size={content.usage.listIconSize ?? 6}
                  />
                </div>
                <h3 class="text-page-inverse text-xl font-semibold mt-0 mb-0">{item.title}</h3>
              </div>
              <p class="text-content">
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-how-we-share-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-how-we-share-title"
      >
        {content.sharing.title}
        <HeadingAnchor href={"#privacy-how-we-share-title"} />
      </h2>
      <div
        class="bg-yellow-50 border border-yellow-200 rounded-xl px-8 pt-8 pb-4"
      >
        <div class="flex items-start">
          <div class="shrink-0">
            <Icon
              icon="warning"
              color="gray-700"
              classes="mt-1"
              size={8}
            />
          </div>
          <div class="text-gray-700 ml-4">
            <h3 class="text-gray-700 mb-2 mt-1.5">{content.sharing.subtitle}</h3>
            <p class="text-gray-700">{content.sharing.description}</p>
            <List
              variant="colored-marker-list"
              items={content.sharing.listItems}
              classes={{
                ul: "text-gray-700",
              }}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-data-security-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-data-security-title"
      >
        {content.security.title}
        <HeadingAnchor href={"#privacy-data-security-title"} />
      </h2>
      <p class="text-content mb-6">
        {content.security.description}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          content.security.cards.map((item) => (
            <div class="text-center">
              <div
                class:list={["w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4", item.background]}
              >
                <Icon
                  icon={item.icon}
                  color={item.color}
                  size={8}
                />
              </div>
              <h3 class="text-gray-700 text-xl font-semibold mb-2">{item.lead}</h3>
              <p class="text-gray-700 text-sm">
                {item.text}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-your-rights-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-your-rights-title"
      >
        {content.rights.title}
        <HeadingAnchor href={"#privacy-your-rights-title"} />
      </h2>
      <div class="bg-white rounded-xl p-6 shadow-md">
        <p class="text-gray-700 mb-6 mt-2">
          {content.rights.description}
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            content.rights.cards.map((item) => (
              <div class="flex items-start">
                <div class="mt-1 mr-3 shrink-0">
                  <Icon
                    icon={item.icon}
                    color={item.color}
                    size={6}
                  />
                </div>
                <div class="pl-1">
                  <h3 class="text-gray-700 text-lg font-semibold mb-2 mt-0.5">{item.lead}</h3>
                  <p class="text-gray-700 text-sm">{item.text}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-cookies-and-tracking-title">
      <h2
        class="text-page-inverse mb-0 sm:mb-6"
        id="privacy-cookies-and-tracking-title"
      >
        {content.cookies.title}
        <HeadingAnchor href={"#privacy-cookies-and-tracking-title"} />
      </h2>
      <p class="text-content mb-6">
        {content.cookies.description}
      </p>
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-gray-700 text-lg font-semibold mb-4 mt-2">
          {content.cookies.subtitle}
        </h3>
        <List
          variant="colored-marker-list"
          items={content.cookies.listItems}
          classes={{
            em: "text-gray-700",
            li: "[&_span]:text-content-offset",
            ul: "pl-6",
          }}
        />
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-storage-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-storage-title"
      >
        {content.storage.title}
        <HeadingAnchor href={"#privacy-storage-title"} />
      </h2>
      <p class="text-content mb-6">
        {content.storage.description}
      </p>
      <div class="bg-white rounded-xl p-6 shadow-md">
        <h3 class="text-lg font-semibold text-gray-700 mb-4 mt-0">
          {content.storage.subtitle}
        </h3>
        <div class="space-y-4">
          <List
            variant="accent-border-left-list"
            items={content.storage.listItems as unknown as {
              title?: string
              lead?: string
              text: string
              icon?: string
              color?: string
            }[]}
          />
        </div>
        <div
          class="mt-8 bg-blue-50 border border-blue-200 rounded-lg px-4 pt-0 pb-0"
        >
          <p class="text-sm text-content-offset leading-relaxed" set:html={content.storage.trailer}></p>
        </div>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-error-monitoring-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-error-monitoring-title"
      >
        {content.monitoring.title}
        <HeadingAnchor href={"#privacy-error-monitoring-title"} />
      </h2>
      <p class="text-content-offset mb-6">
        {content.monitoring.description}
      </p>
      <div class="bg-blue-50 rounded-xl px-8 py-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-700 mb-4 mt-0">
          {content.monitoring.list1.lead}
        </h3>
        <List
          variant="colored-marker-list"
          items={content.monitoring.list1.listItems.map((item) => ({
            lead: item.heading,
            text: item.text,
            color: "bg-blue-600",
          }))}
          classes={{
            ul: "sm:pl-6",
            li: "text-gray-700",
          }}
        />
      </div>

      <div class="bg-green-50 rounded-xl px-8 py-6 mb-6">
        <h3 class="text-lg font-semibold text-gray-700 mb-4 mt-0 flex items-center">
          <Icon
            icon={"shield"}
            color={"text-green-600"}
            size={6}
            classes={"mr-3"}
          />
          {content.monitoring.list2.lead}
        </h3>
        <List
          variant="check-icons-list"
          items={content.monitoring.list2.listItems}
        />
      </div>
      <div class="bg-gray-50 rounded-xl p-6">
        <h3 class="text-lg font-semibold text-gray-700 mb-3 mt-0">
          {content.monitoring.close.heading}
        </h3>
        <p class="text-gray-600 mb-0">
          {content.monitoring.close.text}
        </p>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="privacy-contact-us-title">
      <h2
        class="text-2xl md:text-3xl font-bold text-page-inverse mb-6"
        id="privacy-contact-us-title"
      >
        {content.contact.title}
        <HeadingAnchor href={"#privacy-contact-us-title"} />
      </h2>
      <div class="bg-blue-50 rounded-xl p-6">
        <p class="text-gray-600 mt-0 mb-6">
          {content.contact.description}
        </p>
        <div class="grid grid-cols-1 gap-6 md:mx-12 md:grid-cols-2">
          <div class="flex min-w-0 items-start">
            <div
              class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center ml-3 mt-1 shrink-0 md:ml-6"
            >
              <Icon
                icon={"email"}
                color={"blue-600"}
                size={8}
              />
            </div>
            <div class="ml-4 min-w-0 md:ml-6">
              <h3 class="text-lg font-semibold text-blue-600 mt-0 mb-1">
                {content.contact.card1.lead}
              </h3>
              <a
                href={content.contact.card1.link}
                class="text-blue-600 underline decoration-dotted decoration-current underline-offset-2 transition-colors hover:text-blue-500 focus-visible:text-blue-500 break-all"
              >
                {content.contact.card1.text}
              </a>
            </div>
          </div>
          <div class="flex min-w-0 items-start">
            <div
              class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center ml-3 mt-1 shrink-0 md:ml-6"
            >
              <Icon
                icon={"location"}
                color={"blue-600"}
                size={8}
              />
            </div>
            <div class="ml-4 min-w-0 md:ml-6">
              <h3 class="text-lg font-semibold text-blue-600 mt-0 mb-1">
                {content.contact.card2.lead}
              </h3>
              <p class="text-gray-600 wrap-break-word">
                {content.contact.card2.text}
              </p>
            </div>
          </div>
        </div>

        <div class="border-t border-blue-200">
          <h3 class="text-gray-900 mb-3">
            {content.contact.card3.lead}
          </h3>
          <p class="text-gray-600 mb-4">
            {content.contact.card3.text}
          </p>
          <div class="inline-block max-w-full bg-white rounded-lg px-8 py-4">
            <p class="text-gray-900 font-medium mt-0 mb-0">
              {contactData.company.dataProtectionOfficer.name}
            </p>
            <a
              href={`mailto:${contactData.company.dataProtectionOfficer.email}`}
              class="text-blue-600 underline decoration-dotted decoration-current underline-offset-2 transition-colors hover:text-blue-500 focus-visible:text-blue-500 break-all"
            >
              {contactData.company.dataProtectionOfficer.email}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section aria-labelledby="privacy-changes-to-policy-title">
      <h2
        class="text-page-inverse mb-6"
        id="privacy-changes-to-policy-title"
      >
        {content.changes.title}
        <HeadingAnchor href={"#privacy-changes-to-policy-title"} />
      </h2>
      <div class="bg-gray-50 rounded-xl px-8 py-2">
        <p class="text-gray-600">
          {content.changes.description}
        </p>
      </div>
    </section>
  </div>
</div>
