---
import HeadingAnchor from '@components/Layout/HeadingAnchor/index.astro'
import Icon from '@components/Icon/index.astro'

export type Props = {
  content: {
    header: {
      effectiveDate: string
    }
    sections: {
      header: string
      order: number
      items: {
        text: string
        listItems?: string[]
      }[]
    }[]
  }
}

type Section = Props['content']['sections'][number]
type SectionItem = Section['items'][number]

const { content } = Astro.props

/** Map section order to an icon name and background color for visual variety. */
const sectionMeta: Record<number, { icon: string }> = {
  1: { icon: 'copyright' },
  2: { icon: 'warning' },
  3: { icon: 'external' },
  4: { icon: 'conversation' },
  5: { icon: 'document' },
  6: { icon: 'message' },
}

/**
 * Slugify a section header for use as an anchor id.
 */
function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '')
}
---

<div class="mx-auto max-w-4xl px-4 sm:px-6 pb-4 md:pb-12">
  {/* Header */}
  <header class="mb-10 text-center">
    <p class="text-sm font-medium tracking-wide uppercase text-content-offset mb-2">
      {content.header.effectiveDate}
    </p>
  </header>

  {/* Sections */}
  <div class="space-y-12 mt-6">
    {
      content.sections.map((section: Section) => {
        const meta = sectionMeta[section.order] ?? { icon: 'info' }
        const sectionId = `terms-${slugify(section.header)}`

        return (
          <section aria-labelledby={sectionId}>
            <div class="flex items-center gap-4 sm:ml-12 mb-4">
              <div
                class:list={[
                  'w-10 h-10 rounded-lg flex items-center justify-center shrink-0 bg-page-inverse',
                ]}
              >
                <Icon icon={meta.icon} color="content-inverse" size={5} />
              </div>
              <h2 class="text-page-inverse text-2xl font-semibold mt-0 mb-0" id={sectionId}>
                {section.header}
                <HeadingAnchor href={`#${sectionId}`} />
              </h2>
            </div>

            <div class="bg-primary-inverse rounded-xl px-8 py-6 border border-trim [&_a]:inline-flex [&_a]:min-h-6 [&_a]:items-center [&_a]:align-middle">
              {section.items.map((item: SectionItem) => (
                <div class="mb-4 last:mb-0">
                  <p class="text-content leading-relaxed mb-2" set:html={item.text} />
                  {item.listItems && item.listItems.length > 0 && (
                    <ul class="list-disc list-outside ml-6 space-y-2 text-content">
                      {item.listItems.map((li: string) => (
                        <li class="leading-relaxed" set:html={li} />
                      ))}
                    </ul>
                  )}
                </div>
              ))}
            </div>
          </section>
        )
      })
    }
  </div>
</div>
