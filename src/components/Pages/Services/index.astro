---
import type { CollectionEntry } from 'astro:content'
import './index.css'

type Props = {
  services: CollectionEntry<'services'>[]
}

const { services }: Props = Astro.props

const normalizeServiceId = (serviceId: string) =>
  serviceId
    .toLowerCase()
    .replace(/[^a-z0-9_-]+/g, '-')
    .replace(/^-+|-+$/g, '')

const servicesHeadingAnchorClasses = [
  'group',
  'inline-flex',
  'min-h-6',
  'min-w-6',
  'items-center',
  'justify-center',
  'align-middle',
  'transition-colors',
  'no-underline',
  'hover:no-underline',
  'focus-visible:no-underline',
  'ml-1.5',
].join(' ')

const ensureServicesHeadingAnchorClasses = (html: string) =>
  html.replace(
    /<a class="([^"]*)"([^>]*)aria-label="Link to this section"([^>]*)>/g,
    (_match, _currentClasses: string, beforeAria: string, afterAria: string) =>
      `<a class="${servicesHeadingAnchorClasses}"${beforeAria}aria-label="Link to this section"${afterAria}>`
  )

const namespaceServiceHeadingAnchors = (html: string, serviceId: string) => {
  if (!html.trim()) {
    return html
  }

  const idPrefix = normalizeServiceId(serviceId)
  const remappedIds = new Map<string, string>()

  const htmlWithNamespacedIds = html.replace(/\bid="([^"]+)"/g, (_match, currentId: string) => {
    const nextId = `${idPrefix}-${currentId}`
    remappedIds.set(currentId, nextId)
    return `id="${nextId}"`
  })

  const htmlWithNamespacedHrefs = htmlWithNamespacedIds.replace(
    /\bhref="#([^"]+)"/g,
    (match, currentHref: string) => {
      const nextHref = remappedIds.get(currentHref)
      return nextHref ? `href="#${nextHref}"` : match
    }
  )

  return ensureServicesHeadingAnchorClasses(htmlWithNamespacedHrefs)
}

/**
 * Splits rendered markdown at each <h2> boundary so we can place
 * sections in a two-column layout.
 */
const splitH2Sections = (html: string): string[] => {
  if (!html.trim()) {
    return []
  }

  return html
    .split(/(?=<h2\b)/g)
    .map(section => section.trim())
    .filter(Boolean)
}
---

<services-page class="block" data-testid="services-page-web-component">
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 sm:pt-6 sm:pb-12">
    {services.length > 0 && (
      <div class="services-grid grid gap-8 md:grid-cols-2">
        {services.map((service, i) => {
          const namespacedHtml = namespaceServiceHeadingAnchors(service.rendered?.html ?? '', service.id)
          const sections = splitH2Sections(namespacedHtml)
          const leftSections = sections.slice(0, 2).join('')
          const rightSections = sections.slice(2, 4).join('')
          const projectType = service.data.accountType
          const contactHref = projectType
            ? `/contact?type=${encodeURIComponent(projectType)}`
            : '/contact'

          return (
            <article
              data-service-card
              class:list={[
                'service-card relative flex flex-col rounded-2xl border border-trim overflow-hidden transition-shadow hover:shadow-lg focus-within:shadow-lg',
                i === 0 ? 'service-card--default' : '',
              ]}
            >
              <a
                href={contactHref}
                data-service-contact-link
                data-account-type={projectType}
                class="absolute inset-0 z-(--z-raised) no-underline hover:no-underline focus-visible:no-underline focus-visible:outline-none"
                aria-label={`Contact us about ${service.data.title}`}
              >
                <span class="sr-only">Contact us about {service.data.title}</span>
              </a>

              <div
                class:list={[
                  'service-card-header px-6 py-5 bg-page-offset text-page-inverse',
                  i === 0 ? 'service-card-header--default' : '',
                ]}
              >
                {i === 0 && (
                  <span class="mb-2 inline-block rounded-full bg-spotlight px-3 py-0.5 text-xs font-bold uppercase tracking-wider text-primary">
                    Most Popular
                  </span>
                )}
                <h2 class="text-xl font-bold">{service.data.title}</h2>
                <p
                  class:list={[
                    'service-card-description sm:mt-2 text-sm leading-relaxed text-content-offset',
                    i === 0 ? 'service-card-description--default' : '',
                  ]}
                >
                  {service.data.description}
                </p>
              </div>

              <div class="service-card-body flex flex-1 flex-col bg-content-inverse px-6 py-6">
                <div class="grid gap-6 md:grid-cols-2">
                  <div class="space-y-6 [&_h2]:text-sm [&_h2]:font-semibold [&_h2]:uppercase [&_h2]:tracking-wider [&_h2]:text-page-inverse [&_h2]:mb-2 [&_h2]:mt-0 [&_p]:text-content [&_p]:text-sm [&_p]:leading-relaxed [&_ul]:space-y-1.5 [&_ul]:text-sm [&_ul]:text-content [&_ul]:list-none [&_ul]:pl-0 [&_li]:flex [&_li]:items-start [&_li]:gap-2 [&_li]:before:content-['✓'] [&_li]:before:text-success [&_li]:before:mt-0.5 [&_li]:before:shrink-0">
                    <Fragment set:html={leftSections} />
                  </div>
                  <div class="space-y-6 [&_h2]:text-sm [&_h2]:font-semibold [&_h2]:uppercase [&_h2]:tracking-wider [&_h2]:text-page-inverse [&_h2]:mb-2 [&_h2]:mt-0 [&_p]:text-content [&_p]:text-sm [&_p]:leading-relaxed [&_strong]:text-page-inverse">
                    <Fragment set:html={rightSections} />
                  </div>
                </div>
              </div>
            </article>
          )
        })}
      </div>
    )}
  </section>
</services-page>

<script>
  import { registerServicesPageWebComponent } from '@components/Pages/Services/client/index'
  registerServicesPageWebComponent()
</script>
