---
import { companyContactData } from '@lib/content/contactData'

const address = `${companyContactData.address}, ${companyContactData.city}, ${companyContactData.state} ${companyContactData.index}`
const mapAriaLabel = `Map showing ${companyContactData.name} location`
---

<div class="w-full" data-company-map data-address={address} aria-label={mapAriaLabel}>
  <gmpx-api-loader></gmpx-api-loader>
  <gmp-map class="block w-full h-112" center="0,0" zoom="2" aria-label={mapAriaLabel}>
    <gmp-advanced-marker></gmp-advanced-marker>
  </gmp-map>
</div>

<script>
  import { registerCompanyMap } from './client'
  registerCompanyMap()
</script>
