---
import './index.css'

export type Props = {
  /** The currently active variant, used to determine the position of the switcher thumb */
  currentVariant: 'overview' | 'deep-dive'
  /** Shared slug used to navigate between overview and deep-dive routes */
  slug: string
}

const { currentVariant, slug } = Astro.props
---

<content-switcher current-variant={currentVariant} slug={slug}></content-switcher>

<script>
  import { registerContentSwitcherComponent } from '@components/Content/Switcher/client'
  registerContentSwitcherComponent()
</script>
