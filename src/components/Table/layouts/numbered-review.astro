---
export type Props = {
  content: {
    caption?: string
    subcaption?: string
    thead?: {
      th: string[]
    }
    tbody: {
      tr: {
        th?: string | { label: string; color?: string }
        td: string[]
      }[]
    }
    tfoot?: {
      tr: {
        th?: string
        td: string[]
      }[]
    }
  }
  classes?: {
    table?: string
    caption?: string
    thead?: string
    tbody?: string
    tfoot?: string
  }
  fullWidth?: boolean
}

const { content, classes, fullWidth = true }: Props = Astro.props

const tableClass = `text-left${fullWidth ? ' w-full' : ''}`
const captionClass = 'text-left px-4 py-3 text-content-offset'
const headerClass = 'px-4 py-3 font-semibold text-content-active'
const theadClass = 'bg-page-offset border-b border-trim'
const tbodyClass = ''
const tfootClass = ''
const rowClass = 'transition-colors duration-150 hover:bg-page-offset border-b border-trim-offset last:border-b-0'
---

<table class:list={[tableClass, classes?.table]}>
    {content.caption && (
      <caption class:list={[captionClass, classes?.caption]} set:html={content.caption}></caption>
    )}
    {content.subcaption && (
      <caption class:list={[captionClass, classes?.caption]} set:html={content.subcaption}></caption>
    )}

    {content.thead && (
      <thead class:list={[theadClass, classes?.thead]}>
        <tr>
          <th class="w-14 px-3 py-3 font-semibold text-content-active">#</th>
          {content.thead.th.map((th) => (
            <th scope="col" class:list={[headerClass, classes?.thead]} set:html={th}></th>
          ))}
        </tr>
      </thead>
    )}

    <tbody class:list={[tbodyClass, classes?.tbody]}>
      {content.tbody.tr.map((row, rowIndex) => (
        <tr class={rowClass}>
          <td class="px-3 py-3 text-content-offset font-mono">{rowIndex + 1}</td>
          {row.th && (
            <th
              scope="row"
              class:list={['px-4 py-3 text-page-inverse', classes?.tbody]}
              set:html={row.th}
            ></th>
          )}
          {row.td.map((td, index) => (
            <td
              class:list={[
                'px-4 py-3',
                index === 0 ? 'text-content font-semibold' : '',
                index === 1 ? 'text-content' : '',
                classes?.tbody,
              ]}
              set:html={td}
            ></td>
          ))}
        </tr>
      ))}
    </tbody>

    {content.tfoot && (
      <tfoot class:list={[tfootClass, classes?.tfoot]}>
        {content.tfoot.tr.map((row, rowIndex) => (
          <tr class={rowClass}>
            <td class="px-3 py-3 text-content-offset font-mono">{rowIndex + 1}</td>
            {row.th && (
              <th scope="row" class:list={['px-4 py-3 text-content font-semibold', classes?.tfoot]} set:html={row.th}></th>
            )}
            {row.td.map((td, index) => (
              <td
                class:list={[
                  'px-4 py-3',
                  index === 1 ? 'text-content-offset' : 'text-content',
                  index === 0 ? 'font-semibold' : '',
                  classes?.tfoot,
                ]}
                set:html={td}
              ></td>
            ))}
          </tr>
        ))}
      </tfoot>
    )}
</table>
