---
export type Props = {
  content: {
    caption?: string
    subcaption?: string
    thead?: {
      th: string[]
    }
    tbody: {
      tr: {
        th?: string | { label: string; color?: string }
        td: Array<string | { label: string; color?: string }>
      }[]
    }
    tfoot?: {
      tr: {
        th?: string
        td: Array<string | { label: string; color?: string }>
      }[]
    }
  }
  classes?: {
    table?: string
    caption?: string
    thead?: string
    tbody?: string
    tfoot?: string
  }
  fullWidth?: boolean
}

const { content, classes, fullWidth = true }: Props = Astro.props

const tableClass = `text-left border-collapse${fullWidth ? ' w-full' : ''}`
const captionClass = 'text-left px-5 py-3 text-content-offset'
const headerClass = 'px-5 py-3 font-semibold text-content'
const theadClass = 'bg-note-inverse/50 border-b border-trim'
const tbodyClass = ''
const tfootClass = ''

const stateClasses = {
  note: {
    rowBgClass: 'bg-note-inverse',
    barClass: 'bg-note',
    textClass: 'text-note-offset',
  },
  success: {
    rowBgClass: 'bg-success-inverse',
    barClass: 'bg-success',
    textClass: 'text-success-offset',
  },
  warning: {
    rowBgClass: 'bg-warning-inverse',
    barClass: 'bg-warning',
    textClass: 'text-warning-offset',
  },
  danger: {
    rowBgClass: 'bg-danger-inverse',
    barClass: 'bg-danger',
    textClass: 'text-danger-offset',
  },
  info: {
    rowBgClass: 'bg-info-inverse',
    barClass: 'bg-info',
    textClass: 'text-info-offset',
  },
} as const

type SemanticStateName = keyof typeof stateClasses

const isSemanticStateName = (value: string): value is SemanticStateName => {
  return value === 'note' || value === 'success' || value === 'warning' || value === 'danger' || value === 'info'
}

const firstBodyRow = content.tbody.tr[0]
const hasRowHeaders = content.tbody.tr.some(row => row.th !== undefined)
const bodyColumnCount = hasRowHeaders
  ? (firstBodyRow?.td.length ?? 0) + 1
  : (firstBodyRow?.td.length ?? 0)
const shouldPrependStateHeader = hasRowHeaders && content.thead?.th.length === bodyColumnCount - 1
const headerCells = shouldPrependStateHeader ? ['State', ...(content.thead?.th ?? [])] : (content.thead?.th ?? [])

const getStateClass = (row: Props['content']['tbody']['tr'][number], rowIndex: number) => {
  if (typeof row.th === 'object' && row.th?.color && isSemanticStateName(row.th.color)) {
    return stateClasses[row.th.color]
  }

  switch (rowIndex % 4) {
    case 0:
      return stateClasses.success
    case 1:
      return stateClasses.warning
    case 2:
      return stateClasses.danger
    default:
      return stateClasses.info
  }
}

const getStateLabel = (row: Props['content']['tbody']['tr'][number]): string => {
  if (typeof row.th === 'object') {
    return row.th.label
  }

  const firstCell = row.td[0]

  return row.th ?? (firstCell ? getCellLabel(firstCell) : '')
}

const getCellLabel = (cell: string | { label: string; color?: string }) => {
  return typeof cell === 'string' ? cell : cell.label
}

const getCellStateClass = (cell: string | { label: string; color?: string }) => {
  if (typeof cell === 'object' && cell.color && isSemanticStateName(cell.color)) {
    return stateClasses[cell.color]
  }

  return undefined
}
---

<table class:list={[tableClass, classes?.table]}>
    {content.caption && (
      <caption class:list={[captionClass, classes?.caption]} set:html={content.caption}></caption>
    )}
    {content.subcaption && (
      <caption class:list={[captionClass, classes?.caption]} set:html={content.subcaption}></caption>
    )}

    {content.thead && (
      <thead class:list={[theadClass, classes?.thead]}>
        <tr>
          {headerCells.map((th) => (
            <th scope="col" class:list={[headerClass, classes?.thead]} set:html={th}></th>
          ))}
        </tr>
      </thead>
    )}

    <tbody class:list={[tbodyClass, classes?.tbody]}>
      {content.tbody.tr.map((row, rowIndex) => {
        const stateClass = getStateClass(row, rowIndex)

        return (
          <tr class:list={[
            'border-b last:border-b-0 border-trim',
            stateClass.rowBgClass,
          ]}>
            <td class="px-5 py-3 font-bold relative">
              <span class={stateClass.textClass}>
                {getStateLabel(row)}
              </span>
            </td>
            {row.th ? (
              row.td.map((td, index) => (
                <td
                  class:list={[
                    'px-5 py-3',
                    index === 0 ? 'font-medium text-content' : 'text-content',
                    classes?.tbody,
                  ]}
                >
                  {(() => {
                    const cellStateClass = getCellStateClass(td)

                    if (!cellStateClass) {
                      return <span set:html={getCellLabel(td)}></span>
                    }

                    return (
                      <span
                        class:list={[
                          'inline-flex rounded-md px-2.5 py-1 font-medium',
                          cellStateClass.rowBgClass,
                          cellStateClass.textClass,
                        ]}
                        set:html={getCellLabel(td)}
                      ></span>
                    )
                  })()}
                </td>
              ))
            ) : (
              row.td.map((td, index) => (
                <td
                  class:list={[
                    'px-5 py-3',
                    index === 0 ? 'font-medium text-content' : 'text-content',
                    classes?.tbody,
                  ]}
                >
                  {(() => {
                    const cellStateClass = getCellStateClass(td)

                    if (!cellStateClass) {
                      return <span set:html={getCellLabel(td)}></span>
                    }

                    return (
                      <span
                        class:list={[
                          'inline-flex rounded-md px-2.5 py-1 font-medium',
                          cellStateClass.rowBgClass,
                          cellStateClass.textClass,
                        ]}
                        set:html={getCellLabel(td)}
                      ></span>
                    )
                  })()}
                </td>
              ))
            )}
          </tr>
        )
      })}
    </tbody>

    {content.tfoot && (
      <tfoot class:list={[tfootClass, classes?.tfoot]}>
        {content.tfoot.tr.map((row, rowIndex) => {
          const fallbackRow: Props['content']['tbody']['tr'][number] =
            row.th !== undefined
              ? {
                th: row.th as string,
                td: row.td,
              }
              : {
                td: row.td,
              }
          const stateClass = getStateClass(fallbackRow, rowIndex)

          return (
            <tr class:list={[
              'border-b last:border-b-0 border-trim',
              stateClass.rowBgClass,
            ]}>
              <td class="px-5 py-3 font-bold relative">
                <div class:list={['absolute inset-y-0 left-0 w-1', stateClass.barClass]} />
                <span class={stateClass.textClass}>
                  {row.th ?? (row.td[0] ? getCellLabel(row.td[0]) : '')}
                </span>
              </td>
              {row.th ? (
                row.td.map((td, index) => (
                  <td
                    class:list={[
                      'px-5 py-3',
                      index === 0 ? 'font-medium text-content' : 'text-content',
                      classes?.tfoot,
                    ]}
                  >
                    {(() => {
                      const cellStateClass = getCellStateClass(td)

                      if (!cellStateClass) {
                        return <span set:html={getCellLabel(td)}></span>
                      }

                      return (
                        <span
                          class:list={[
                            'inline-flex rounded-md px-2.5 py-1 font-medium',
                            cellStateClass.rowBgClass,
                            cellStateClass.textClass,
                          ]}
                          set:html={getCellLabel(td)}
                        ></span>
                      )
                    })()}
                  </td>
                ))
              ) : (
                row.td.map((td, index) => (
                  <td
                    class:list={[
                      'px-5 py-3',
                      index === 0 ? 'font-medium text-content' : 'text-content',
                      classes?.tfoot,
                    ]}
                  >
                    {(() => {
                      const cellStateClass = getCellStateClass(td)

                      if (!cellStateClass) {
                        return <span set:html={getCellLabel(td)}></span>
                      }

                      return (
                        <span
                          class:list={[
                            'inline-flex rounded-md px-2.5 py-1 font-medium',
                            cellStateClass.rowBgClass,
                            cellStateClass.textClass,
                          ]}
                          set:html={getCellLabel(td)}
                        ></span>
                      )
                    })()}
                  </td>
                ))
              )}
            </tr>
          )
        })}
      </tfoot>
    )}
</table>
