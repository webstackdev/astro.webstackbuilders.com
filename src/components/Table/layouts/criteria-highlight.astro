---
export type Props = {
  content: {
    caption?: string
    subcaption?: string
    thead?: {
      th: string[]
    }
    tbody: {
      tr: {
        th?: string | { label: string; color?: string }
        td: string[]
      }[]
    }
    tfoot?: {
      tr: {
        th?: string
        td: string[]
      }[]
    }
  }
  classes?: {
    table?: string
    caption?: string
    thead?: string
    tbody?: string
    tfoot?: string
  }
}

const { content, classes }: Props = Astro.props

const tableClass = 'w-full text-left'
const captionClass = 'text-left px-4 py-3 text-content-offset'
const headerClass = 'px-4 py-2.5 font-semibold text-content-active'
const theadClass = 'bg-page-offset border-b border-trim'
const rowClass = 'transition-colors duration-150 hover:bg-page-offset border-b border-trim-offset last:border-b-0'
---


<table class:list={[tableClass, classes?.table]}>
  {content.caption && (
    <caption class:list={[captionClass, classes?.caption]} set:html={content.caption}></caption>
  )}
  {content.subcaption && (
    <caption class:list={[captionClass, classes?.caption]} set:html={content.subcaption}></caption>
  )}

  {content.thead && (
    <thead class:list={[theadClass, classes?.thead]}>
      <tr>
        {content.thead.th.map((th) => (
          <th scope="col" class:list={[headerClass, classes?.thead]} set:html={th}></th>
        ))}
      </tr>
    </thead>
  )}

  <tbody class:list={[classes?.tbody]}>
    {content.tbody.tr.map((row) => (
      <tr class={rowClass}>
        {row.th && (
          <th scope="row" class:list={['px-4 py-3 text-content font-medium', classes?.tbody]} set:html={row.th}></th>
        )}
        {row.td.map((td, index) => (
          index === 1 ? (
            <td class:list={['px-4 py-3', classes?.tbody]}>
              <span class="inline-flex rounded-md border border-primary-offset bg-primary-inverse px-2.5 py-1 text-primary-offset" set:html={td}></span>
            </td>
          ) : (
            <td
              class:list={[
                'px-4 py-3',
                index === 0 ? 'text-content font-medium' : 'text-content',
                classes?.tbody,
              ]}
              set:html={td}
            ></td>
          )
        ))}
      </tr>
    ))}
  </tbody>

  {content.tfoot && (
    <tfoot class:list={[classes?.tfoot]}>
      {content.tfoot.tr.map((row) => (
        <tr class={rowClass}>
          {row.th && (
            <th scope="row" class:list={['px-4 py-3 text-content font-medium', classes?.tfoot]} set:html={row.th}></th>
          )}
          {row.td.map((td, index) => (
            index === 1 ? (
              <td class:list={['px-4 py-3', classes?.tfoot]}>
                <span class="inline-flex rounded-md border border-secondary bg-secondary-inverse px-2.5 py-1 text-secondary font-semibold" set:html={td}></span>
              </td>
            ) : (
              <td
                class:list={[
                  'px-4 py-3',
                  index === 0 ? 'text-content font-medium' : 'text-content',
                  classes?.tfoot,
                ]}
                set:html={td}
              ></td>
            )
          ))}
        </tr>
      ))}
    </tfoot>
  )}
</table>
