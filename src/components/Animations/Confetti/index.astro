---
/**
 * Short-lived confetti animation.
 *
 * The client web component respects global animation lifecycle state via the store.
 */
export interface Props {
  /** Additional classes to add to the component wrapper */
  classes: string
}

const { classes } = Astro.props
---

<confetti-animation
  class:list={["confetti-animation relative block", classes]}
  data-testid="confetti-animation"
>
  <canvas
    data-confetti-canvas
    aria-hidden="true"
    class="absolute inset-0 w-full h-full pointer-events-none z-(--z-content-overlay)"
  ></canvas>
  <slot />
</confetti-animation>

<script>
  import { registerConfettiAnimationWebComponent } from '@components/Animations/Confetti/client'
  registerConfettiAnimationWebComponent()
</script>
