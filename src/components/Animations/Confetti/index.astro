---
/**
 * Short-lived confetti animation.
 *
 * The client web component respects global animation lifecycle state via the store.
 */
export interface Props {
  /** Additional classes to add to the component wrapper */
  classes?: string
  /** Additional classes to add to the canvas element */
  canvasClasses?: string
}

const { classes = '', canvasClasses = '' } = Astro.props
---

<confetti-animation
  class:list={["confetti-animation block", classes]}
  data-testid="confetti-animation"
>
  <canvas
    data-confetti-canvas
    aria-hidden="true"
    class:list={[
      'fixed inset-0 h-dvh w-screen pointer-events-none z-(--z-modal)',
      canvasClasses,
    ]}
  ></canvas>
  <slot />
</confetti-animation>

<script>
  import { registerConfettiAnimationWebComponent } from '@components/Animations/Confetti/client'
  registerConfettiAnimationWebComponent()
</script>
