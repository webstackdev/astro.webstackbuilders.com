---
import { Image as AstroImage } from 'astro:assets'
import Icon from '@components/Icon/index.astro'

type ImageSource = {
	src: string
	width: number
	height: number
}

export interface Props {
	src?: ImageSource
	alt?: string
	variant?: 'left' | 'right' | 'center' | 'full'
	loading?: 'lazy' | 'eager'
}

const {
	src,
	alt = '',
	variant = 'center',
	loading = 'lazy',
}: Props = Astro.props

const allowedVariants = ['left', 'right', 'center', 'full'] as const
const resolvedVariant = allowedVariants.includes(variant) ? variant : 'center'
const iconBankId = `content-image-icon-bank-${Math.random().toString(36).slice(2)}`
const openLabel = alt ? `Open expanded view for ${alt}` : 'Open expanded image'
const hostClasses = 'my-6 block w-full'
const figureClassesByVariant = {
	center: 'm-0 w-full max-w-full md:mx-auto md:max-w-3xl',
	left: 'm-0 w-full max-w-full md:mr-auto md:max-w-3xl',
	right: 'm-0 w-full max-w-full md:ml-auto md:max-w-3xl',
	full: 'm-0 w-full max-w-full',
} as const
const figureClasses = figureClassesByVariant[resolvedVariant]
const surfaceClasses = 'relative overflow-hidden rounded-xl border border-trim bg-page-offset'
const assetClasses = 'block h-auto w-full'
const openButtonClasses =
	"absolute top-2 right-2 hidden items-center justify-center border-0 bg-transparent p-1.5 text-icons transition-[color,transform] duration-150 ease-linear hover:scale-[1.03] hover:text-icons-active focus-visible:scale-[1.03] focus-visible:text-icons-active focus-visible:outline-none md:inline-flex after:pointer-events-none after:absolute after:content-[''] after:inset-0 after:rounded-none after:border-2 after:border-transparent after:opacity-0 after:transition-opacity after:duration-150 after:ease-out focus-visible:after:opacity-100 focus-visible:after:-inset-1 focus-visible:after:border-spotlight"
---

{src && (
	<>
		<div id={iconBankId} hidden aria-hidden="true">
			<span data-image-icon="close">
				<Icon icon="close" color="inherit" size={8} />
			</span>
		</div>

		<content-image
			class={hostClasses}
			data-image-variant={resolvedVariant}
			data-testid="content-image"
			icon-bank-id={iconBankId}
			image-alt={alt}
			image-height={String(src.height)}
			image-src={src.src}
			image-width={String(src.width)}
		>
			<div class={figureClasses} data-image-figure>
				<div class={surfaceClasses}>
					<AstroImage
						src={src}
						alt={alt}
						loading={loading}
						class={assetClasses}
						widths={[480, 768, 1024, 1280, 1600]}
						sizes="(min-width: 768px) 48rem, 100vw"
					/>

					{/** Intentionally not using Button component. */}
					<button
						type="button"
						class={openButtonClasses}
						data-image-open
						aria-label={openLabel}
					>
						<Icon icon="magnify" color="inherit" size={8} />
					</button>
				</div>
			</div>

			<div data-image-modal-root></div>
		</content-image>

		<script>
			import { registerImageWebComponent } from '@components/Image/client'

			registerImageWebComponent()
		</script>
	</>
)}
