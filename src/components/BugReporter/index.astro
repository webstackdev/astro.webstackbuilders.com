---
/**
 * BugReporter
 * Renders the Bug Reporter modal custom element and self-registers its web component.
 *
 * The trigger button lives in the Footer (near the RSS icon).
 */
import Icon from '@components/Icon/index.astro'

const {
  triggerId = 'bugReporterTrigger',
  dialogId = 'bugReporterDialog',
  statusId = 'bugReporterStatus',
  formId = 'bugReporterForm',
  closeButtonId = 'bugReporterClose',
  cancelButtonId = 'bugReporterCancel',
  minimizeButtonId = 'bugReporterMinimize',
  minimizedBarId = 'bugReporterMinimizedBar',
  minimizedRestoreButtonId = 'bugReporterRestore',
  minimizedCloseButtonId = 'bugReporterMinimizedClose',
} = Astro.props
---

<bug-reporter-modal-element
  trigger-id={triggerId}
  dialog-id={dialogId}
  status-id={statusId}
  form-id={formId}
  close-button-id={closeButtonId}
  cancel-button-id={cancelButtonId}
  minimize-button-id={minimizeButtonId}
  minimized-bar-id={minimizedBarId}
  minimized-restore-button-id={minimizedRestoreButtonId}
  minimized-close-button-id={minimizedCloseButtonId}
  data-testid="bug-reporter-modal"
></bug-reporter-modal-element>

<dialog
  id={dialogId}
  aria-label="Report a bug"
  class="fixed inset-0 m-auto bg-content-inverse border border-trim rounded-lg p-0 max-w-xl w-[min(42rem,90vw)] shadow-2xl backdrop:bg-page-active/60 overflow-hidden"
>
  <div class="flex items-center justify-between bg-page-inverse px-4 py-2.5">
    <h2 class="text-sm font-semibold text-content-inverse m-0">Report a bug</h2>
    <div class="flex items-center gap-1">
      <button
        id={minimizeButtonId}
        type="button"
        aria-label="Minimize"
        class="flex items-center justify-center w-7 h-7 rounded hover:bg-content-inverse/20 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors"
        title="Minimize"
      >
        <Icon icon="minimize" color="content-inverse" size={3} />
      </button>
      <button
        id={closeButtonId}
        type="button"
        aria-label="Close"
        class="flex items-center justify-center w-7 h-7 rounded hover:bg-danger/80 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors"
        title="Close"
      >
        <Icon icon="close" color="content-inverse" size={3} />
      </button>
    </div>
  </div>

  <div class="p-5">
    <p class="mt-0 mb-4 text-sm text-content-offset">
      Tell us what happened and what you expected.
    </p>

    <form id={formId} class="space-y-3">
      <label class="block">
        <span class="text-sm font-semibold">Name</span>
        <input
          name="name"
          autocomplete="name"
          class="mt-1 w-full rounded-md border border-trim bg-page-base p-2 text-sm focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="Your name"
        />
      </label>

      <label class="block">
        <span class="text-sm font-semibold">Email</span>
        <input
          name="email"
          type="email"
          autocomplete="email"
          class="mt-1 w-full rounded-md border border-trim bg-page-base p-2 text-sm focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="your.email@example.org"
        />
      </label>

      <label class="block">
        <span class="text-sm font-semibold">Description</span>
        <textarea
          name="message"
          required
          rows="4"
          class="mt-1 w-full rounded-md border border-trim bg-page-base p-2 text-sm focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="What's the bug? What did you expect?"
        ></textarea>
      </label>

      <p id={statusId} class="hidden text-sm" aria-live="polite"></p>

      <div class="flex items-center justify-end gap-3 pt-3 border-t border-trim">
        <button
          id={cancelButtonId}
          type="button"
          class="px-4 py-2 text-sm font-semibold rounded-md border border-trim hover:bg-page-offset focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="px-4 py-2 text-sm font-semibold rounded-md bg-page-inverse text-content-inverse hover:opacity-90 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-opacity"
        >
          Send
        </button>
      </div>
    </form>
  </div>
</dialog>

<!-- Minimized bar: shown when the modal is minimized, like a collapsed chat window -->
<div
  id={minimizedBarId}
  class="fixed bottom-4 right-4 z-(--z-content-floating) hidden bg-page-inverse text-content-inverse rounded-lg shadow-2xl select-none"
>
  <div class="flex items-center gap-3 pl-4 pr-2 py-2">
    <button
      id={minimizedRestoreButtonId}
      type="button"
      class="flex items-center gap-3 text-left rounded-md px-0 py-0 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-transform hover:scale-[1.02]"
      aria-label="Restore bug report"
    >
      <Icon icon="bug" color="content-inverse" size={4} />
      <span class="text-sm font-semibold">Bug Report</span>
      <span class="text-xs opacity-70 italic">in progress</span>
    </button>
    <button
      id={minimizedCloseButtonId}
      type="button"
      aria-label="Close bug report"
      class="ml-2 flex items-center justify-center w-6 h-6 rounded hover:bg-danger/80 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors"
    >
      <Icon icon="close" color="content-inverse" size={3} />
    </button>
  </div>
</div>

<script>
  import { registerBugReporterWebComponent } from '@components/BugReporter/client'
  registerBugReporterWebComponent()
</script>
