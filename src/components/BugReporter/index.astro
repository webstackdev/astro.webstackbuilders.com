---
/**
 * BugReporter
 * Renders the Bug Reporter modal custom element and self-registers its web component.
 *
 * The trigger button lives in the Footer (near the RSS icon).
 */
import Icon from '@components/Icon/index.astro'

const {
  triggerId = 'bugReporterTrigger',
  dialogId = 'bugReporterDialog',
  statusId = 'bugReporterStatus',
  formId = 'bugReporterForm',
  closeButtonId = 'bugReporterClose',
  cancelButtonId = 'bugReporterCancel',
} = Astro.props
---

<bug-reporter-modal-element
  trigger-id={triggerId}
  dialog-id={dialogId}
  status-id={statusId}
  form-id={formId}
  close-button-id={closeButtonId}
  cancel-button-id={cancelButtonId}
  data-testid="bug-reporter-modal"
></bug-reporter-modal-element>

<dialog
  id={dialogId}
  aria-label="Report a bug"
  class="fixed inset-0 m-auto bg-page-offset border border-trim rounded-md p-0 max-w-xl w-min-4xl overflow-hidden"
>
  <div class="flex items-center justify-between gap-4 bg-page-inverse border-b border-trim">
    <h2 class="text-base font-bold m-0 pl-1">Report a bug</h2>
    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Minimize"
        class="flex items-center justify-center p-1.5 rounded-sm hover:bg-page-base focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors cursor-not-allowed"
        title="Minimize"
      >
        <Icon icon="minimize" color="content-inverse" size={4} />
      </button>
      <button
        id={closeButtonId}
        type="button"
        aria-label="Close"
        class="flex items-center justify-center p-1.5 rounded-sm bg-spotlight hover:bg-spotlight-offset focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-opacity"
        title="Close"
      >
        <Icon icon="close" color="content-inverse" size={4} />
      </button>
    </div>
  </div>

  <div class="p-5">
    <p class="mt-0 text-base">
      Tell us what happened and what you expected.
    </p>

    <form id={formId} class="mt-4">
      <label class="block">
        <span class="font-bold">Name</span>
        <input
          name="name"
          autocomplete="name"
          class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="Your name"
        />
      </label>

      <label class="block mt-3">
        <span class="font-bold">Email</span>
        <input
          name="email"
          type="email"
          autocomplete="email"
          class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="your.email@example.org"
        />
      </label>

      <label class="block mt-3">
        <span class="font-bold">Description</span>
        <textarea
          name="message"
          required
          rows="5"
          class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-1"
          placeholder="What's the bug? What did you expect?"
        ></textarea>
      </label>

      <p id={statusId} class="mt-3 hidden" aria-live="polite"></p>

      <div class="mt-5 flex items-center justify-end gap-3 border-t border-trim pt-4">
        <button
          id={cancelButtonId}
          type="button"
          class="px-4 py-2 text-sm font-semibold rounded-md border border-trim hover:bg-page-offset focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-colors"
        >
          Cancel
        </button>
        <button
          type="submit"
          class="px-4 py-2 text-sm font-semibold rounded-md bg-page-inverse text-content-inverse hover:opacity-90 focus-visible:outline-2 focus-visible:outline-spotlight focus-visible:outline-offset-2 transition-opacity"
        >
          Send
        </button>
      </div>
    </form>
  </div>
</dialog>

<script>
  import { registerBugReporterWebComponent } from '@components/BugReporter/client'
  registerBugReporterWebComponent()
</script>
