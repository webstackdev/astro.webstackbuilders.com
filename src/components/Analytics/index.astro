---
import { isProd } from '@components/scripts/utils/environmentClient'

const mode = isProd() ? 'production' : 'development'
const paramsStr = JSON.stringify(Astro.params)
const pathname = Astro.url.pathname
---

<vercel-analytics-state data-mode={mode} data-params={paramsStr} data-pathname={pathname}
></vercel-analytics-state>

<script>
  import { queryAnalyticsStateElement } from './client/selectors'
  import { computeRoute, inject, pageview } from '@vercel/analytics'

  const analyticsState = queryAnalyticsStateElement()
  const pathname = analyticsState?.dataset['pathname'] ?? window.location.pathname
  const params = JSON.parse(analyticsState?.dataset['params'] ?? '{}')
  const mode = analyticsState?.dataset['mode'] === 'development' ? 'development' : 'production'

  window.webAnalyticsBeforeSend = event => {
    /** Ignore testing pages in tracking */
    if (event?.url?.includes('/testing/')) {
      return null
    }
    return event
  }

  if (!window.__webstackAnalyticsInjected) {
    inject({
      beforeSend: window.webAnalyticsBeforeSend,
      disableAutoTrack: true,
      framework: 'astro',
      mode,
    })
    window.__webstackAnalyticsInjected = true
  } else {
    window.va?.('beforeSend', window.webAnalyticsBeforeSend)
  }

  pageview({
    path: pathname,
    route: computeRoute(pathname, params),
  })
</script>
