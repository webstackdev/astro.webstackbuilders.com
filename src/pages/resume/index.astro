---
import { getCollection, render } from 'astro:content'
import Resume from '@components/Pages/Resume/index.astro'

const [contactEntry] = await getCollection('contactData')
const [resumeEntry] = await getCollection('resume')

if (!contactEntry) {
  throw new Error('Missing contact data entry')
}

if (!resumeEntry) {
  throw new Error('Missing resume content entry')
}

const contactData = contactEntry.data
const resume = resumeEntry.data

const publishedClients = (await getCollection('clients', ({ data }) => data.published)).sort(
  (a, b) => {
    const left = b.data.endDate?.getTime() ?? b.data.startDate?.getTime() ?? 0
    const right = a.data.endDate?.getTime() ?? a.data.startDate?.getTime() ?? 0

    return left - right
  }
)

const renderedClients = await Promise.all(
  publishedClients.map(async client => ({
    client,
    Content: (await render(client)).Content,
  }))
)

const resumeFullName = `${resume.firstName} ${resume.lastName}`
const pageTitle = `Resume for ${resumeFullName}`
const pageDescription = `Curriculum vitae/resume for ${resumeFullName}`
const path = '/resume'
---

<Resume
  contactData={contactData}
  pageDescription={pageDescription}
  pageTitle={pageTitle}
  path={path}
  renderedClients={renderedClients}
  resume={resume}
/>