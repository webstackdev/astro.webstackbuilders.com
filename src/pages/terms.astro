---
export const prerender = true

import PageLayout from '@layouts/PageLayout.astro'
import TermsOfUsePage from '@components/Pages/TermsOfUse/index.astro'

const pageDescription =
  'Webstack Builders, Inc. Terms of Use: High-quality tech articles (CC BY-NC 4.0) and ready-to-use open-source code (MIT). Stay informed on our usage policies.'
const pageTitle = 'Terms of Use'
const path = '/terms/'
---

<PageLayout
  pageTitle={pageTitle}
  pageDescription={pageDescription}
  icon="document-with-checkmark"
  path={path}
>
  <TermsOfUsePage
    content={{
      header: {
        effectiveDate: 'Effective Date: February 28, 2025',
      },
      sections: [
        {
          header: 'Intellectual Property & Licensing',
          order: 1,
          items: [
            {
              text: 'We believe in sharing knowledge while protecting our original work. To support the developer community, we use a dual-licensing model:',
              listItems: [
                'Articles and Content: Unless otherwise noted, all text, diagrams, images, and video content are the property of Webstack Builders, Inc. and are licensed under the Creative Commons Attribution - Non Commercial 4.0 International (<a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC 4.0</a>) license. You may share and adapt this content for non-commercial purposes, provided you give appropriate credit.',
                'Code Samples: All source code, snippets, and scripts provided within our articles are licensed under the <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT License</a>. You are free to use, modify, and distribute this code in any project, including commercial applications, without further permission.',
              ],
            },
          ],
        },
        {
          header: 'Disclaimers ("As-Is" Policy)',
          order: 2,
          items: [
            {
              text: 'The information provided on this blog is for informational and educational purposes only. No Warranties: All content and code are provided "as-is" without any warranties of any kind, express or implied. We do not guarantee the accuracy, completeness, or suitability of the information for any specific purpose.',
            },
            {
              text: 'Use at Your Own Risk: Any reliance you place on the materials on this site is strictly at your own risk. Webstack Builders, Inc. will not be liable for any losses or damages, including but not limited to system failures or data loss, arising from your use of our code or tutorials.',
            },
          ],
        },
        {
          header: 'Third-Party Links',
          order: 3,
          items: [
            {
              text: 'Our articles may contain links to external websites. We do not control and are not responsible for the content, privacy policies, or practices of any third-party sites.',
            },
          ],
        },
        {
          header: 'User Conduct',
          order: 4,
          items: [
            {
              text: 'If you choose to leave comments or interact with our site, you agree not to post any content that is unlawful, defamatory, or infringing upon the intellectual property rights of others. We reserve the right to remove any content at our discretion.',
            },
          ],
        },
        {
          header: 'Governing Law',
          order: 5,
          items: [
            {
              text: 'These terms are governed by the laws of Delaware, USA, without regard to its conflict of law principles.',
            },
          ],
        },
        {
          header: 'Contact Us',
          order: 6,
          items: [
            {
              text: 'If you have questions regarding these terms or wish to request permission for commercial use of our written content, please contact us at: <a href="mailto:info@webstackbuilders.com" target="_blank" rel="noopener noreferrer">info@webstackbuilders.com</a>.',
            },
          ],
        },
      ],
    }}
  />
</PageLayout>
