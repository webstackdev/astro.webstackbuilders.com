---
export const prerender = true

import { getCollection } from 'astro:content'
import PageLayout from '@layouts/PageLayout.astro'
import ServicesPage from '@components/Pages/Services/index.astro'

/** Get all services from content collection */
const allServices = await getCollection('services')

/** Filter and sort services */
const services = allServices
  .filter(service => !service.data.isDraft)
  .sort((a, b) => a.data.order - b.data.order)

const pageTitle = 'My Services'
const pageDescription =
  'Flexible options from full-time capacity to one-off assessments — all month-to-month with no long-term lock-in.'
const path = '/services/'
---

<PageLayout pageTitle={pageTitle} pageDescription={pageDescription} icon="wrench" path={path}>
  <ServicesPage services={services} />
</PageLayout>
