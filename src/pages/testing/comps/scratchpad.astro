          stroke-width: 0;
          stroke: #0b0b0b;
        }
        #mermaid-0 .arrowheadPath {
          fill: #0b0b0b;
        }
        #mermaid-0 .edgePath .path {
          stroke: #0b0b0b;
          stroke-width: 2px;
        }
        #mermaid-0 .flowchart-link {
          stroke: #0b0b0b;
          fill: none;
        }
        #mermaid-0 .edgeLabel {
          background-color: hsl(-79.4117647059, 100%, 93.3333333333%);
          text-align: center;
        }
        #mermaid-0 .edgeLabel p {
          background-color: hsl(-79.4117647059, 100%, 93.3333333333%);
        }
        #mermaid-0 .edgeLabel rect {
          opacity: 0.5;
          background-color: hsl(-79.4117647059, 100%, 93.3333333333%);
          fill: hsl(-79.4117647059, 100%, 93.3333333333%);
        }
        #mermaid-0 .labelBkg {
          background-color: rgba(243.9999999999, 220.9999999998, 255, 0.5);
        }
        #mermaid-0 .cluster rect {
          fill: hsl(220.5882352941, 100%, 98.3333333333%);
          stroke: hsl(220.5882352941, 60%, 88.3333333333%);
          stroke-width: 1px;
        }
        #mermaid-0 .cluster text {
          fill: rgb(8.5000000002, 5.7500000001, 0);
