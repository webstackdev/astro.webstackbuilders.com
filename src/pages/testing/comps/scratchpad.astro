---
import BaseLayout from '@layouts/BaseLayout.astro'
import './_scratchpad.css'

const pageTitle = 'Scratchpad'
const pageDescription = 'Troubleshooting Component Variants'
const path = '/testing/comps/scratchpad'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div style="margin-top: 64px;">
    <h1>Improved Welcome Email Layout</h1>
    <div aria-label="Welcome to the Webstack Weekly Newsletter" aria-roledescription="email" style="background-color:#f3f4f6; padding: 40px 20px;" role="article" lang="und" dir="auto">
      <div style="background:#ffffff; margin:0px auto; max-width:600px; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
        <table align="center" border="0" cellpadding="0" cellspacing="0" role="presentation" style="background:#ffffff; width:100%;">
          <tbody>
            <!-- Header -->
            <tr>
              <td style="padding: 16px 16px 8px 16px; text-align: left; background: #e5e7eb; border-bottom: 1px solid #d1d5db;">
                <table align="left" border="0" cellpadding="0" cellspacing="0" role="presentation" style="margin: 0;">
                  <tr>
                    <td style="width: 49px; vertical-align: middle;">
                      <a href="https://www.webstackbuilders.com" style="color:#001A39; text-decoration:none; display:inline-block;">
                        <table align="center" cellpadding="0" cellspacing="0" role="presentation" style="width:49px; height:48px; background-color:#ffffff; border:3px solid #ffffff;">
                          <tbody>
                            <tr>
                              <td style="height:17px;"><table cellpadding="0" cellspacing="0" role="presentation" style="width:100%; height:100%; background-color:#ffffff; border:0;"><tbody><tr><td style="width:10px; height:17px; background-color:#001A39;"></td><td style="width:3px; height:17px; background-color:#ffffff;"></td><td style="width:23px; height:17px; background-color:#001A39;"></td><td style="width:3px; height:17px; background-color:#ffffff;"></td><td style="width:10px; height:17px; background-color:#001A39;"></td></tr></tbody></table></td>
                            </tr>
                            <tr><td style="height:3px; background-color:#ffffff; line-height:3px; font-size:3px;">&nbsp;</td></tr>
                            <tr>
                              <td style="height:9px;"><table cellpadding="0" cellspacing="0" role="presentation" style="width:100%; height:100%; background-color:#ffffff; border:0;"><tbody><tr><td style="width:23px; height:9px; background-color:#006DCA;"></td><td style="width:3px; height:9px; background-color:#ffffff;"></td><td style="width:23px; height:9px; background-color:#006DCA;"></td></tr></tbody></table></td>
                            </tr>
                            <tr><td style="height:2px; background-color:#ffffff; line-height:2px; font-size:2px;">&nbsp;</td></tr>
                            <tr>
                              <td style="height:17px;"><table cellpadding="0" cellspacing="0" role="presentation" style="width:100%; height:100%; background-color:#ffffff; border:0;"><tbody><tr><td style="width:10px; height:17px; background-color:#001A39;"></td><td style="width:3px; height:17px; background-color:#ffffff;"></td><td style="width:23px; height:17px; background-color:#001A39;"></td><td style="width:3px; height:17px; background-color:#ffffff;"></td><td style="width:10px; height:17px; background-color:#001A39;"></td></tr></tbody></table></td>
                            </tr>
                          </tbody>
                        </table>
                      </a>
                    </td>
                    <td style="padding-left: 14px; vertical-align: middle; text-align: left;">
                      <a href="https://www.webstackbuilders.com" style="color:#001A39; text-decoration:none; display:block; text-align:left; font-family:Arial, sans-serif; font-size:24px; font-weight:700; line-height:26px;">
                        Webstack Weekly<br>
                        <span style="font-size: 18px; color: #006DCA;">Newsletter</span>
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <!-- Hero -->
            <tr style="margin-top: 24px; margin-bottom: 16px;">
              <td style="padding: 40px 24px 10px; text-align: center;">
                <div style="font-size: 56px; line-height: 56px; margin-bottom: 20px;">🚀</div>
                <h2 style="margin: 0; font-family: Arial, sans-serif; font-size: 28px; font-weight: 700; line-height: 36px; color: #111827;">
                  You're in!
                </h2>
                <p style="margin: 16px 0 0; font-family: Arial, sans-serif; font-size: 18px; line-height: 28px; color: #4b5563;">
                  Welcome to the Webstack Weekly. Get ready for insights on modern web dev, architecture, and engineering.
                </p>
              </td>
            </tr>
            <!-- Content Body -->
            <tr>
              <td style="padding: 10px 40px 32px; text-align: left;">

                <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="width: 100%; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; margin-bottom: 28px;">
                  <tr>
                    <td style="padding: 24px;">
                      <p style="margin: 0 0 16px; font-family: Arial, sans-serif; font-size: 16px; font-weight: 700; color: #1e293b;">Here's what to expect:</p>
                      <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="width: 100%;">
                        <tr>
                          <td style="padding-bottom: 12px; vertical-align: top; width: 24px;">✨</td>
                          <td style="padding-bottom: 12px; font-family: Arial, sans-serif; font-size: 15px; line-height: 24px; color: #334155;"><strong>Deep Dives:</strong> Detailed tutorials and case studies on solving complex engineering challenges.</td>
                        </tr>
                        <tr>
                          <td style="padding-bottom: 12px; vertical-align: top; width: 24px;">📰</td>
                          <td style="padding-bottom: 12px; font-family: Arial, sans-serif; font-size: 15px; line-height: 24px; color: #334155;"><strong>Tech Radar:</strong> The latest industry news, framework updates, and architectural trends.</td>
                        </tr>
                        <tr>
                          <td style="vertical-align: top; width: 24px;">💡</td>
                          <td style="font-family: Arial, sans-serif; font-size: 15px; line-height: 24px; color: #334155;"><strong>Team Spotlight:</strong> Exclusive articles authored directly by our engineering teams.</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>

                <p style="margin: 0 0 24px; font-family: Arial, sans-serif; font-size: 16px; line-height: 26px; color: #333333; text-align: center;">
                  While you wait for our next issue, check out some of our most popular guides!
                </p>

                <!-- Primary Action -->
                <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="width: 100%; margin-bottom: 24px;">
                  <tr>
                    <td align="center">
                      <a href="https://www.webstackbuilders.com/articles" style="display:inline-block; background:#0066cc; color:#ffffff; font-family:Arial, sans-serif; font-size:16px; font-weight:600; line-height:120%; margin:0; text-decoration:none; text-transform:none; padding:16px 40px; border-radius:6px;" target="_blank">
                        Explore Latest Articles
                      </a>
                    </td>
                  </tr>
                </table>

              </td>
            </tr>
            <!-- Minimal Footer w/ Unsubscribe -->
            <tr>
              <td style="padding: 24px 40px; background: #f8fafc; text-align: center; border-top: 1px solid #f0f0f0;">
                <p style="margin: 0 0 12px; font-family: Arial, sans-serif; font-size: 13px; line-height: 18px; color: #64748b;">
                  You are receiving this email because you opted in to receive our newsletter.<br>
                  <a href="https://www.webstackbuilders.com/unsubscribe?token={{unsubscribeToken}}" style="color: #0066cc; text-decoration: underline;">Unsubscribe from these emails</a>.
                </p>
                <p style="margin: 0; font-family: Arial, sans-serif; font-size: 12px; line-height: 18px; color: #94a3b8;">
                  © 2026 Webstack Builders, Inc.<br>
                    1032 E. Brandon Boulevard, Suite 5230, Brandon, FL 33511<br>
                    1 (888) 987 1881 • 1 (302) 608 6864
                </p>
              </td>
            </tr>
          </tbody>
        </table>
                        <![endif]-->
                      </td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <!--[if mso | IE]>
            </td>
          </tr>
        </table>
        <![endif]-->
      </div>
  </div>
</BaseLayout>
