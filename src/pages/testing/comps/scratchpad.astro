---
import '@components/Social/Highlighter/index.css'
import BaseLayout from '@layouts/BaseLayout.astro'

const pageTitle = 'Scratchpad'
const pageDescription = 'Troubleshooting Component Variants'
const path = '/testing/comps/scratchpad'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div class="test-container mx-auto mb-24 flex min-h-[calc(100vh-18rem)] w-full items-center justify-center px-6 py-12">

    <div data-search-panel="" data-state="open" class="relative z-(--z-modal) w-full max-w-(--header-search-panel-width-open)">
      <div data-search-results="" class="z-(--z-content-floating) overflow-hidden rounded-lg border border-trim bg-(--color-gray-300) shadow-elevated" data-search-listener="true">
        <ul data-search-results-list="" class="divide-y divide-border" aria-label="Search suggestions">
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#when-kubernetes-fits">
              When Kubernetes Fits
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#choosing-the-right-tool">
              Choosing the Right Tool
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use">
              When Not to Use Kubernetes: A Decision Framework
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#the-hidden-costs">
              The Hidden Costs
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#the-kubernetes-complexity-tax">
              The Kubernetes Complexity Tax
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#score-your-situation">
              Score Your Situation
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-decision-framework-when-not-to-use#what-youre-actually-signing-up-for">
              What You're Actually Signing Up For
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="https://www.webstackbuilders.com/articles/kubernetes-secrets-external-secrets-operator-csi-vault#the-two-patterns-that-matter">
              The Two Patterns That Matter
            </a>
          </li>
          <li class="px-4 py-3 hover:bg-page-offset">
            <a class="block text-body" href="/search?q=kubernetes">
              Search for "kubernetes"
            </a>
          </li>
        </ul>
      </div>
    </div>

  </div>
</BaseLayout>
