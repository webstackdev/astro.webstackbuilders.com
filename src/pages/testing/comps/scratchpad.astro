---
import BaseLayout from '@layouts/BaseLayout.astro'

const pageTitle = 'Scratchpad'
const pageDescription = 'Troubleshooting Component Variants'
const path = '/testing/comps/scratchpad'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div class="">

    <dialog id="bugReporterDialog" aria-label="Report a bug" class="bg-content-inverse border border-trim rounded-md p-4 max-w-xl w-[min(42rem,90vw)]" open="">
      <div class="flex items-start justify-between gap-4">
        <h2 class="text-xl font-bold">Report a bug</h2>
        <div style="display: contents">
          <button
            id="bugReporterClose"
            type="button"
            class=""
          >
            <span>Close</span>
          </button>
        </div>
      </div>
      <p class="mt-2 text-base">
        Tell us what happened and what you expected.
      </p>
      <form id="bugReporterForm" class="mt-4">
        <label class="block">
          <span class="font-bold">Name</span>
          <input
            name="name"
            autocomplete="name"
            class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2"
            placeholder="Your name"
          >
        </label>
        <label class="block mt-3">
          <span class="font-bold">Email</span>
          <input
            name="email"
            type="email"
            autocomplete="email"
            class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2"
            placeholder="your.email@example.org"
          >
        </label>
        <label class="block mt-3">
          <span class="font-bold">Description</span>
          <textarea
            name="message"
            required=""
            rows="5"
            class="mt-1 w-full rounded-md border border-trim bg-page-offset p-2"
            placeholder="What's the bug? What did you expect?"
          ></textarea>
        </label>
        <p id="bugReporterStatus" class="mt-3 hidden" aria-live="polite"></p>
        <div class="mt-4 flex items-center gap-3">
          <div style="display: contents">
            <button
              type="submit"
              class=""
            >
              Send
            </button>
          </div>
          <div style="display: contents">
            <button
              type="button"
              class=""
              id="bugReporterCancel"
            >
              <span>Cancel</span>
            </button>
          </div>
        </div>
      </form>
    </dialog>

  </div>
</BaseLayout>

