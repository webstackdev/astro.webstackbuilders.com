---
import '@components/Social/Highlighter/index.css'
import BaseLayout from '@layouts/BaseLayout.astro'

const pageTitle = 'Scratchpad'
const pageDescription = 'Troubleshooting Component Variants'
const path = '/testing/comps/scratchpad'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <section class="mx-auto mb-24 flex w-full max-w-7xl flex-col gap-8 px-6 py-12">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">

      <section class="space-y-4">
        <div class="overflow-hidden rounded-lg border border-trim bg-page-offset shadow-elevated">
          <ul class="divide-y divide-border" aria-label="Search suggestions">
            <li class="group cursor-pointer hover:bg-note-inverse">
              <a
                class="flex items-center justify-between gap-4 px-4 py-4 no-underline hover:no-underline focus-visible:no-underline"
                href="/deep-dive/introduction-to-vector-search"
              >
                <div class="min-w-0">
                  <div class="mb-1 font-mono text-xs text-content transition-colors group-hover:text-content-active">
                    /deep-dive/introduction-to-vector-search
                  </div>
                  <div class="mb-1 text-body font-bold text-page-inverse transition-colors group-hover:text-content-active">
                    Introduction to <strong class="bg-warning-inverse">Vector</strong> Search
                  </div>
                  <p class="line-clamp-1 text-sm text-content-offset transition-colors group-hover:text-content-active">
                    Learn the basics of how <strong class="bg-warning-inverse text-content">vector</strong> databases work.
                  </p>
                </div>
                <svg class="h-4 w-4 shrink-0 text-gray-400 transition group-hover:translate-x-1 group-hover:text-content-active" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </li>

            <li class="group cursor-pointer hover:bg-note-inverse">
              <a
                class="flex items-center justify-between gap-4 px-4 py-4 no-underline hover:no-underline focus-visible:no-underline"
                href="/deep-dive/introduction-to-vector-search"
              >
                <div class="min-w-0">
                  <div class="mb-1 font-mono text-xs text-content transition-colors group-hover:text-content-active">
                    /deep-dive/introduction-to-vector-search
                  </div>
                  <div class="mb-1 text-body font-bold text-page-inverse transition-colors group-hover:text-content-active">
                    Introduction to <strong class="bg-warning-inverse">Vector</strong> Search
                  </div>
                  <p class="line-clamp-1 text-sm text-content-offset transition-colors group-hover:text-content-active">
                    Learn the basics of how <strong class="bg-warning-inverse text-content">vector</strong> databases work.
                  </p>
                </div>
                <svg class="h-4 w-4 shrink-0 text-gray-400 transition group-hover:translate-x-1 group-hover:text-content-active" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </li>
          </ul>
        </div>
      </section>

    </div>
  </section>
</BaseLayout>
