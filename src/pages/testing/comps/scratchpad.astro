}

const variants = [
  { id: 'variant-4', title: 'Variant 4: Divided Context Card', text: 'Share Selection' },
];
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div class="test-container max-w-4xl mx-auto py-12 px-6 space-y-24 mb-24">
    <div>
      <h1 class="text-3xl font-bold mb-4">Highlighter Share Dialog Styling</h1>
      <p class="text-content-offset">Review the variants below to decide which setup looks best.</p>
    </div>

    {variants.map(variant => (
      <div class="variant-wrapper border border-trim-offset rounded-lg p-16 flex flex-col items-center justify-center min-h-75 relative bg-page-base">
        <h2 class="text-lg font-semibold absolute top-4 left-6">{variant.title}</h2>

        <!-- Center the container to show off the modal clearly -->
        <div class="relative pt-12">
          <highlighter-element aria-label="Share this">
            <span class="highlighter__wrapper block">
              <button
                type="button"
                class="highlighter__trigger"
                aria-controls={`share-dialog-${variant.id}`}
                aria-expanded="true"
              >
                <span class="highlighter__content text-content bg-warning-inverse rounded px-2 py-0.5 whitespace-nowrap">
                  Selected content block here...
                </span>
              </button>
              <span
                class={`share-dialog ${variant.id}`}
                role="toolbar"
                aria-hidden="false"
                id={`share-dialog-${variant.id}`}
                aria-label="Share this"
              >
                {variant.text && <span class="share-dialog__text">{variant.text}</span>}
                <span class="share-dialog__buttons">
                  <button type="button" class="share-button" style="color: var(--color-x);" set:html={icons.x} />
                  <button type="button" class="share-button" style="color: var(--color-linkedin);" set:html={icons.linkedin} />
                  <button type="button" class="share-button" style="color: var(--color-bluesky);" set:html={icons.bluesky} />
                  <button type="button" class="share-button" style="color: var(--color-reddit);" set:html={icons.reddit} />
                  <button type="button" class="share-button" style="color: var(--color-mastodon);" set:html={icons.mastodon} />
                </span>
                <span class="share-dialog__arrow"></span>
              </span>
            </span>
          </highlighter-element>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  /* ==========================================================
     Shared adjustments
     ========================================================== */
  .variant-wrapper { background-color: var(--color-page-base); }
  highlighter-element { display: block; }

  highlighter-element .share-dialog {
    /* Hardcode visibility for testing so it's always open above the trigger */
    display: block !important;
    bottom: calc(100% + 0.75rem) !important;
    margin: 0 !important;
    min-width: max-content;
  }

  /* Make sure content is above the arrow */
  highlighter-element .share-dialog__text,
  highlighter-element .share-dialog__buttons {
    position: relative;
    z-index: 10;
  }

  highlighter-element .share-dialog__text {
    font-size: 0.875rem;
    font-weight: 600;
  }

  /* Base styling for the bordered arrow caret */
  highlighter-element .share-dialog__arrow {
    border: none !important; /* Reset the triangle hack from index.css */
    width: 0.75rem !important;
    height: 0.75rem !important;
    position: absolute;
    left: 50%;
    transform: translateX(-50%) rotate(45deg) !important;
    bottom: -0.375rem !important; /* Half showing out the bottom */
    background-color: inherit;
    border-bottom-width: 1px !important;
    border-right-width: 1px !important;
    border-bottom-style: solid !important;
    border-right-style: solid !important;
    z-index: 1; /* Keep it above parent border but behind buttons */
    pointer-events: none;
  }

  /* ==========================================================
     Variant 4: Divided Context Card
     ========================================================== */
  .variant-4 {
    display: flex !important;
    align-items: center;
    border-radius: 0.5rem !important;
    /* Reduced vertical height requested */
    padding: 0.125rem 0.375rem !important;
    background-color: var(--color-page-base) !important;
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
    border: 1px solid var(--color-trim-offset);
  }

  /* Slightly shrink buttons so the vertical height reduces further */
  .variant-4 .share-button {
    width: 2.125rem !important;
    height: 2.125rem !important;
    padding: 0.4rem !important;
    border-radius: 9999px !important;
    transition: background-color 0.2s ease, transform 0.1s ease !important;
  }

  /* Added slight grey background on hover and upwards nudge */
  .variant-4 .share-button:hover {
    background-color: var(--color-page-offset) !important;
    transform: translateY(-1px) !important;
  }

  .variant-4 .share-dialog__text {
    font-size: 0.875rem;
    color: var(--color-content);
    /* Reduced spacing around the text */
    padding: 0 0.5rem 0 0.25rem !important;
    margin-right: 0.125rem !important;
  }

  .variant-4 .share-dialog__arrow {
    border-bottom-color: var(--color-trim-offset) !important;
    border-right-color: var(--color-trim-offset) !important;
  }
</style>
