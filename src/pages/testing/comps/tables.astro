---
import BaseLayout from '@layouts/BaseLayout.astro'
import Table from '@components/Table/index.astro'
import { tableContent } from '@content/articles/demo/index.ts'

const pageDescription = 'Styling Variants'
const pageTitle = 'Style Variants'
const path = '/hero/'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div>
    <h1>Table Component Layouts</h1>

    <section>
      <h2>criteria-highlight</h2>
      <Table variant="criteria-highlight-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>grid-and-accent-header</h2>
      <Table variant="grid-and-accent-header-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>minimal-borders</h2>
      <Table variant="minimal-borders-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>numbered-review</h2>
      <Table variant="numbered-review-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>report-table</h2>
      <Table variant="report-table" content={tableContent.reportTableContent} />
    </section>

    <section>
      <h2>semantic-coloring</h2>
      <Table variant="semantic-coloring-table" content={tableContent.semanticTableContent} />
    </section>

    <section>
      <h2>soft-header-card</h2>
      <Table variant="soft-header-card-table" content={tableContent.softHeaderCardContent} />
    </section>

    <section>
      <h2>sticky-header</h2>
      <Table variant="sticky-header-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>striped-rows</h2>
      <Table variant="striped-rows-table" content={tableContent.baseTableContent} />
    </section>

    <section>
      <h2>timeline-labels</h2>
      <Table variant="timeline-labels-table" content={tableContent.timelineTableContent} />
    </section>

    <section>
      <h2>vertical-column-delineation</h2>
      <Table variant="vertical-column-delineation-table" content={tableContent.baseTableContent} />
    </section>
  </div>
</BaseLayout>
