---
import BaseLayout from '@layouts/BaseLayout.astro'
import CalendarComponent from '@components/Calendar/index.astro'

export const prerender = false

const pageTitle = 'Calendar Component Test Fixture'
const fixtureDescription =
  'Dedicated route reserved for validating the Add to Calendar component with deterministic event metadata.'
const pagePath = '/testing/calendar'
---

<BaseLayout pageTitle={pageTitle} path={pagePath} pageDescription={fixtureDescription} noindex>
  <section class="mx-auto flex max-w-4xl flex-col items-center gap-8 px-4 py-10">
    <header class="max-w-3xl text-center space-y-4">
      <p class="text-xs uppercase tracking-widest text-content-active">Testing Fixture</p>
      <h1 class="text-3xl font-semibold leading-tight">{pageTitle}</h1>
      <p class="text-content-active">{fixtureDescription}</p>
    </header>

    <article class="w-full max-w-2xl space-y-6 rounded-lg border border-trim bg-page-offset p-6 shadow-sm">
      <div class="space-y-2">
        <p class="text-xs uppercase tracking-wider text-content-active">Fixture Event</p>
        <h2 class="text-2xl font-semibold">Team sync</h2>
        <p class="text-content-active">
          Stable event data for validating Google Calendar, Outlook, and `.ics` download actions.
        </p>
      </div>

      <div class="flex justify-center">
        <CalendarComponent
          name="Team sync"
          startDate="2030-01-02"
          startTime="13:00"
          endDate="2030-01-02"
          endTime="14:00"
          location="Remote"
          description="Weekly team sync"
        >
          Add to calendar
        </CalendarComponent>
      </div>
    </article>
  </section>
</BaseLayout>