---
import { dsarVerificationEmailText } from '@actions/gdpr/email/dsarText'

export const prerender = false

const text = dsarVerificationEmailText({
  actionText: 'delete your data',
  expiresIn: '24 hours',
  requestType: 'DELETE',
  verifyUrl: 'https://www.webstackbuilders.com/privacy/my-data?token=mock-dsar-token-123',
})
---

<pre>{text}</pre>
