---
import BaseLayout from '@layouts/BaseLayout.astro'

const pageDescription = 'Hero Demo Pages'
const pageTitle = 'Hero Demo Pages'
const path = '/hero/'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <main class="mx-auto max-w-7xl space-y-16 px-4 py-12 sm:px-6 lg:px-8">
    <header class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight text-content-active">Contact CTA Variants</h1>
      <p class="text-content-offset">Four design options for the Contact Us call-to-action section.</p>

    </header>
  </main>
</BaseLayout>
