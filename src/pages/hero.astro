---
import BaseLayout from '@layouts/BaseLayout.astro'
import Table from '@components/Table/index.astro'

const pageDescription = 'Styling Variants'
const pageTitle = 'Style Variants'
const path = '/hero/'

const rows = [
  { classification: 'Actionable', criteria: '≥ 80%', action: 'Keep, improve runbook' },
  { classification: 'Noisy', criteria: '20-80%', action: 'Investigate thresholds, consider aggregation' },
  { classification: 'Useless', criteria: '< 20%', action: 'Delete or convert to dashboard metric' },
  { classification: 'Stale', criteria: 'Not fired in 3+ months', action: 'Review for deletion' },
]

const getTimelineColor = (index: number): 'success' | 'warning' | 'danger' | 'info' => {
  switch (index % 4) {
    case 0:
      return 'success'
    case 1:
      return 'warning'
    case 2:
      return 'danger'
    default:
      return 'spotlight'
  }
}

const getSemanticColor = (index: number): 'success' | 'warning' | 'danger' | 'info' => {
  switch (index % 4) {
    case 0:
      return 'success'
    case 1:
      return 'warning'
    case 2:
      return 'danger'
    default:
      return 'info'
  }
}

const baseTableContent = {
  figure: 'Alert classification buckets based on action rate.',
  thead: {
    th: ['Classification', 'Criteria', 'What To Do'],
  },
  tbody: {
    tr: rows.map(row => ({
      td: [row.classification, row.criteria, row.action],
    })),
  },
}

const semanticTableContent = {
  figure: 'Alert classification buckets based on action rate.',
  thead: {
    th: ['Criteria', 'Remediation'],
  },
  tbody: {
    tr: rows.map((row, index) => ({
      th: {
        label: row.classification,
        color: getSemanticColor(index),
      },
      td: [row.criteria, row.action],
    })),
  },
}

const timelineTableContent = {
  figure: 'Alert classification buckets based on action rate.',
  thead: {
    th: ['Classification', 'Criteria', 'What To Do'],
  },
  tbody: {
    tr: rows.map((row, index) => ({
      th: {
        label: row.classification,
        color: getTimelineColor(index),
      },
      td: [row.criteria, row.action],
    })),
  },
}

const reportTableContent = {
  caption: 'Alert triage reference matrix',
  figure: 'Alert classification buckets based on action rate.',
  thead: {
    th: ['Classification', 'Criteria', 'What To Do'],
  },
  tbody: {
    tr: rows.map(row => ({
      td: [row.classification, row.criteria, row.action],
    })),
  },
}

const softHeaderCardContent = {
  caption: 'Alert Classification Guide',
  subcaption: 'Use this to quickly decide action priority.',
  figure: 'Alert classification buckets based on action rate.',
  thead: {
    th: ['Classification', 'Criteria', 'What To Do'],
  },
  tbody: {
    tr: rows.map(row => ({
      td: [row.classification, row.criteria, row.action],
    })),
  },
}
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div class="mt-12 space-y-16 px-4 pb-16 max-w-5xl mx-auto">
    {/* ================================================================
        criteria-highlight — Matrix with Highlighted Criteria
        Emphasizes the criteria column for scanning thresholds.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">criteria-highlight</h2>
      <Table variant="criteria-highlight-table" content={baseTableContent} />
      <p>Paragraph text below.</p>
    </section>

    {/* ================================================================
        grid-and-accent-header — Bordered grid with accent header
        Full grid lines, header uses secondary color.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">grid-and-accent-header</h2>
      <Table variant="grid-and-accent-header-table" content={baseTableContent} />
    </section>

    {/* ================================================================
        minimal-borders — Minimal with bottom borders only
        Clean, borderless look with subtle row separators.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">minimal-borders</h2>
      <Table variant="minimal-borders-table" content={baseTableContent} />
    </section>

    {/* ================================================================
        numbered-review — Numbered Ranking Table
        Adds index column for ordered review workflows.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">numbered-review</h2>
      <Table variant="numbered-review-table" content={baseTableContent} />
    </section>

    {/* ================================================================
        report-table — Caption + Strong Top Rule
        Classic report-table aesthetic with clear hierarchy.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">report-table</h2>
      <Table variant="report-table" content={reportTableContent} />
    </section>

    {/* ================================================================
        semantic-coloring — Status Color Coded
        Uses semantic warning/success/info colors based on row index
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">semantic-coloring</h2>
      <Table variant="semantic-coloring-table" content={semanticTableContent} />
    </section>

    {/* ================================================================
        soft-header-card — Soft Card Header + Divided Body
        Contrasting card header and gentle body dividers.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">soft-header-card</h2>
      <Table variant="soft-header-card-table" content={softHeaderCardContent} />
    </section>

    {/* ================================================================
        sticky-header — Hover-highlight rows with sticky header
        Subtle hover effect, header sticks on scroll.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">sticky-header</h2>
      <Table variant="sticky-header-table" content={baseTableContent} />
    </section>

    {/* ================================================================
        striped-rows — Striped rows with rounded container
        Alternating row colors inside a rounded card.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">striped-rows</h2>
      <Table variant="striped-rows-table" content={baseTableContent} />
    </section>

    {/* ================================================================
        timeline-labels — Horizontal Timeline Emphasis
        First column acts like timeline labels with markers.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">timeline-labels</h2>
      <Table variant="timeline-labels-table" content={timelineTableContent} />
    </section>

    {/* ================================================================
        vertical-column-delineation — Column Separation (Vertical Borders Only)
        Focuses on delineating columns instead of rows.
        ================================================================ */}
    <section>
      <h2 class="text-2xl font-bold mb-4">vertical-column-delineation</h2>
      <Table variant="vertical-column-delineation-table" content={baseTableContent} />
    </section>
  </div>
</BaseLayout>
