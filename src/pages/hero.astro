---
import BaseLayout from '@layouts/BaseLayout.astro'
import Shares from '@components/Social/Shares/index.astro'

const pageDescription = 'Styling Variants'
const pageTitle = 'Style Variants'
const path = '/hero/'
const shareDemoUrl = 'https://www.webstackbuilders.com/articles/strangler-fig-migration-complete-guide'
const shareDemoTitle = 'Strangler Fig Migrations: Validate Before You Cut Over'
const shareDemoDescription = `Read "${shareDemoTitle}" on Webstack Builders`
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <div class="mt-12">
    <section
      class="rounded-lg bg-page-offset flex flex-col md:flex-row items-start md:items-center p-6 mx-6"
      aria-labelledby="share-v17"
    >
      <div class="h-full w-full sm:border-r sm:border-trim sm:w-auto sm:shrink-0 sm:pr-12">
        <h2
          class="text-2xl font-black tracking-tight text-content-active leading-tight flex flex-row sm:flex-col items-start gap-2 sm:gap-0"
          id="share-v17"
        >
          <span>Share</span>
          <span>this</span>
          <span>article</span>
        </h2>
      </div>
      <div class="w-full md:flex-1 sm:pl-12">
        <p class="text-content text-sm mb-4">
          Enjoyed the read? Share it with your network.
        </p>
        <Shares
          url={shareDemoUrl}
          title={shareDemoTitle}
          description={shareDemoDescription}
          class="justify-start"
        />
      </div>
    </section>
  </div>
</BaseLayout>
