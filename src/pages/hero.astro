---
import BaseLayout from '@layouts/BaseLayout.astro'
import Table from '@components/Table/index.astro'

const pageDescription = 'Styling Variants'
const pageTitle = 'Style Variants'
const path = '/hero/'
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
<Table
  variant="vertical-column-delineation-table"
  content={{
    figure: "Label cardinality management strategies for gateway metrics.",
    thead: { th: ["Dimension", "Cardinality Risk", "Mitigation"] },
    tbody: {
      tr: [
        { th: "Consumer ID", td: ["High (thousands)", "Use only on counters, not histograms"] },
        { th: "Route", td: ["Medium (hundreds)", "Use route pattern, not full path"] },
        { th: "Upstream Instance", td: ["Medium", "Aggregate to upstream name"] },
        { th: "Status Code", td: ["Low (tens)", "Safe to use everywhere"] },
        { th: "Method", td: ["Very Low (<10)", "Safe to use everywhere"] },
      ],
    },
  }}
/>
</BaseLayout>
