---
import BaseLayout from '@layouts/BaseLayout.astro'
import Shares from '@components/Social/Shares/index.astro'

const pageDescription = 'Styling Variants'
const pageTitle = 'Style Variants'
const path = '/hero/'
const shareDemoUrl = 'https://www.webstackbuilders.com/articles/strangler-fig-migration-complete-guide'
const shareDemoTitle = 'Strangler Fig Migrations: Validate Before You Cut Over'
const shareDemoDescription = `Read "${shareDemoTitle}" on Webstack Builders`

/* Shared breadcrumb data for all variants */
const crumbs = [
  { label: 'Home', href: '/' },
  { label: 'Articles', href: '/articles' },
  { label: 'Why Your E2E Tests Are Flaky (And How to Fix Them)' },
]
---

<BaseLayout pageDescription={pageDescription} noindex={true} pageTitle={pageTitle} path={path}>
  <h1 class="text-2xl font-bold text-content-active mb-8">{pageTitle}</h1>

  <section class="mb-16" aria-labelledby="social-share-copilot-variants-title">
    <!-- Variant 17 — Two-column asymmetric: large heading left, buttons right -->
    <article class="rounded-lg border border-trim bg-page-base p-6">
      <h3 class="text-base font-semibold text-content-active mb-6 border-b border-trim pb-2">Variant 17 - Asymmetric Two-Column</h3>

      <section class="rounded-lg bg-page-offset grid grid-cols-1 md:grid-cols-3 gap-6 items-center p-6 mx-6" aria-labelledby="share-v17">
        <div class="md:col-span-1">
          <h2 class="text-2xl font-black tracking-tight text-content-active leading-tight" id="share-v17">
            Share<br />this<br />article
          </h2>
        </div>
        <div class="md:col-span-2 md:border-l border-trim md:pl-6">
          <p class="text-content text-sm mb-4">
            Enjoyed the read? Share it with your network.
          </p>
          <Shares
            url={shareDemoUrl}
            title={shareDemoTitle}
            description={shareDemoDescription}
            class="justify-start"
          />
        </div>
      </section>
    </article>
  </section>

  <main class="space-y-16 pb-16">
    {/* ------------------------------------------------------------------ */}
    {/* Variant 4 — Card Chips with Icons                                 */}
    {/* Each crumb is a mini card with a home/folder/file icon and a      */}
    {/* connecting dashed line between them.                               */}
    {/* ------------------------------------------------------------------ */}
    <section>
      <h2 class="text-lg font-semibold text-content-active mb-3">Variant 4 — Card Chips with Icons</h2>
      <nav aria-label="Breadcrumbs" class="breadcrumbs sm:pl-4">
        <ol class="flex flex-wrap items-center gap-0 text-sm">
          {crumbs.map((crumb, i) => (
            <li class="flex items-center">
              {i > 0 && (
                <span class="w-6 h-px border-t-2 border-dashed border-trim-offset" />
              )}
              {crumb.href ? (
                <a href={crumb.href} class="inline-flex items-center gap-1.5 rounded-md border border-page-inverse bg-page-base px-3 py-1.5 text-page-inverse no-underline shadow-sm transition-all duration-200 hover:border-secondary hover:shadow-md focus-visible:border-secondary focus-visible:shadow-md">
                  {i === 0 ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-page-inverse" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1" />
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-page-inverse" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                    </svg>
                  )}
                  {crumb.label}
                </a>
              ) : (
                <span aria-current="page" class="inline-flex items-center gap-1.5 rounded-md bg-page-inverse px-3 py-1.5 font-medium text-content-inverse">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                  </svg>
                  {crumb.label}
                </span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* Variant 8 — Ghost Buttons                                         */}
    {/* Each crumb is a bordered button that fills on hover. Separated by  */}
    {/* simple text arrows.                                                */}
    {/* ------------------------------------------------------------------ */}
    <section>
      <h2 class="text-lg font-semibold text-content-active mb-3">Variant 8 — Ghost Buttons</h2>
      <nav aria-label="Breadcrumbs" class="breadcrumbs sm:pl-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm">
          {crumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && (
                <span class="text-trim-offset font-bold">→</span>
              )}
              {crumb.href ? (
                <a href={crumb.href} class="rounded-md border border-trim px-3 py-1.5 text-content no-underline transition-all duration-200 hover:bg-page-inverse hover:text-content-inverse focus-visible:bg-secondary focus-visible:text-secondary-inverse">
                  {crumb.label}
                </a>
              ) : (
                <span aria-current="page" class="rounded-md border border-page-inverse bg-page-inverse/5 px-3 py-1.5 font-medium text-page-inverse">
                  {crumb.label}
                </span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* Variant 16 — Dot Matrix                                           */}
    {/* Links are separated by a tiny matrix of dots for texture.          */}
    {/* ------------------------------------------------------------------ */}
    <section>
      <h2 class="text-lg font-semibold text-content-active mb-3">Variant 16 — Dot Matrix</h2>
      <nav aria-label="Breadcrumbs" class="breadcrumbs sm:pl-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-content">
          {crumbs.map((crumb, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && (
                <span class="grid grid-cols-2 gap-0.5" aria-hidden="true">
                  <span class="h-1 w-1 rounded-full bg-gray-300" />
                  <span class="h-1 w-1 rounded-full bg-gray-300" />
                  <span class="h-1 w-1 rounded-full bg-gray-300" />
                  <span class="h-1 w-1 rounded-full bg-gray-300" />
                </span>
              )}
              {crumb.href ? (
                <a href={crumb.href} class="rounded px-3 py-1 text-gray-900 no-underline transition-colors bg-gray-300 hover:bg-gray-400 hover:text-white focus-visible:text-white focus-visible:bg-gray-400">
                  {crumb.label}
                </a>
              ) : (
                <span aria-current="page" class="rounded px-3 py-1 text-secondary-inverse bg-page-inverse">
                  {crumb.label}
                </span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </section>

    {/* ------------------------------------------------------------------ */}
    {/* Variant 20 — Connected Circles (from breadcrumb-1.png)            */}
    {/* Numbered circles connected by a solid line, with labels below.     */}
    {/* ------------------------------------------------------------------ */}
    <section>
      <h2 class="text-lg font-semibold text-content-active mb-3">Variant 20 — Connected Circles</h2>
      <nav aria-label="Breadcrumbs" class="breadcrumbs sm:pl-4 pt-4">
        <ol class="relative flex w-full max-w-2xl items-start justify-between text-sm">
          {/* Background connecting line */}
          <div class="absolute left-0 top-5 -z-10 h-1 w-full bg-page-offset" aria-hidden="true">
            {/* Active progress line (assuming 2 of 3 steps complete for demo) */}
            <div class="h-full w-1/2 bg-page-inverse" />
          </div>

          {crumbs.map((crumb, i) => {
            return (
              <li class="flex flex-col items-center gap-3">
                {crumb.href ? (
                  <a href={crumb.href} class="group flex flex-col items-center gap-3 no-underline">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full border-4 border-page-base bg-page-inverse text-lg font-bold text-page-inverse shadow-[0_0_0_2px_var(--color-page-offset)] transition-colors duration-200 group-hover:bg-page-inverse">
                      {i + 1}
                    </span>
                    <span class="text-page-inverse transition-colors duration-200 group-hover:text-page-inverse">
                      {crumb.label}
                    </span>
                  </a>
                ) : (
                  <span class="flex flex-col items-center gap-3">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full border-4 border-page-base bg-page-base text-lg font-bold text-page-inverse shadow-[0_0_0_2px_var(--color-page-offset)]">
                      {i + 1}
                    </span>
                    <span class="font-medium text-content-offset">
                      {crumb.label}
                    </span>
                  </span>
                )}
              </li>
            )
          })}
        </ol>
      </nav>
    </section>
  </main>
</BaseLayout>
