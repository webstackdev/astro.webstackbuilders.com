<style>
  html {
  height: auto;
  min-height: 100%;
  overflow-y: auto; }

  body {
  background-color: lightgrey;
  color: black;
  font-family: var(--font-sans);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
  min-height: 100%;
  overflow-y: auto; }

a {
  color: black; }

.container {
  background-color: white;
  padding: 1em; }

.sectionHr {
  background-color: black;
  height: 2px;
  margin-bottom: 0.5em;
  width: 100%; }

.githubIcon {
  fill: #171515; }

.linkedinIcon {
  fill: #0A66C2; }

.twitterIcon {
  fill: #00ACEE; }

.youtubeIcon path, .youtubeIcon polygon {
  fill: #F00; }

*, *::before, *::after {
  box-sizing: border-box; }

* {
  margin: 0; }

html, body {
  height: auto;
  min-height: 100%; }

abbr {
  text-decoration: none; }

input, button, textarea, select {
  font: inherit; }

button {
  background: none;
  border: none;
  color: inherit;
  cursor: pointer;
  font: inherit;
  outline: inherit;
  padding: 0; }

hr {
  border: none; }

p, h1, h2, h3 {
  overflow-wrap: break-word; }

svg {
  display: block;
  max-width: 100%; }

/** Achievements, Strengths */
.asideList {
  padding-left: 0; }

.asideItem {
  display: flex;
  flex-direction: row;
  list-style: none; }

  .asideItem:not(:first-child) {
    margin-top: 5px; }

.asideHeader {
  font-size: 1.1em; }

.asideIcons {
  flex-shrink: 0; }

  .asideIcons svg {
    fill: #C41230;
    margin-top: 6px; }

.asideContent {
  margin-left: 10px; }

@media print {
  .asideIcons svg {
    fill: black; } }

/** Languages */
.languageList {
  margin-left: 5px;
  padding-left: 0; }

.languageItem {
  display: flex;
  flex-direction: row;
  list-style: none; }

  .languageItem:not(:last-child) {
    margin-bottom: 5px; }

.languageName {
  font-weight: bold;
  width: 6em; }

.languageRating {
  align-items: start;
  display: flex;
  fill: lightgrey;
  flex-direction: row;
  margin-top: 6px; }

.languageRating-5 span {
  fill: #C41230; }

.languageRating-1 span:nth-of-type(1) {
  fill: #C41230; }

.languageRating-2 span:nth-of-type(1),
.languageRating-2 span:nth-of-type(2) {
  fill: #C41230; }

.languageRating-3 span:nth-of-type(1),
.languageRating-3 span:nth-of-type(2),
.languageRating-3 span:nth-of-type(3) {
  fill: #C41230; }

