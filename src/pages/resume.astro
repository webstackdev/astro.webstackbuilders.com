      {resume.education.school}
      </div>
      <div class="mainDetails">
      <span
        class="mainDetailHeader"
        itemprop="Role"
        itemscope
        itemtype="https://schema.org/Role"
        >
      <span class="mainDetailIcon"><svg width="18px" height="18px" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
