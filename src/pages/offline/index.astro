---
import PageLayout from '@layouts/PageLayout.astro'
import NetworkStatus from '@components/Toasts/NetworkStatus/index.astro'
import Offline from '@components/Pages/Offline/index.astro'

const pageTitle = 'Offline - Webstack Builders'
const pageDescription =
  'Offline fallback for Webstack Builders with guidance on what to do until you reconnect.'
const path = 'offline'
---

<PageLayout pageTitle={pageTitle} pageDescription={pageDescription} path={path} icon="waiting">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-2 md:py-4">
    <!-- Network status monitoring -->
    <NetworkStatus />
    <Offline
      content={{
        title: "You're Offline",
        message: "It looks like your connection dropped. We'll be here when you're back.",
        items: {
          label: 'What You Can Do While Offline',
          cards: [
            {
              title: 'Outline Your Project',
              text: 'Think through your platform goals, infrastructure needs, and engineering priorities.',
              icon: 'document',
              color: 'blue-600',
              bgColor: 'blue-100',
            },
            {
              title: 'Define Your Requirements',
              text: 'Document your reliability targets, CI/CD pipeline needs, and developer enablement goals.',
              icon: 'clipboard-checked',
              color: 'green-600',
              bgColor: 'green-100',
            },
            {
              title: 'Map Your Architecture',
              text: 'Sketch your system topology, service dependencies, and deployment strategy on paper.',
              icon: 'map',
              color: 'purple-600',
              bgColor: 'purple-100',
            },
            {
              title: 'Prepare Your Questions',
              text: 'Jot down questions about testing frameworks, cloud migrations, or incident response for our team.',
              icon: 'question',
              color: 'orange-600',
              bgColor: 'orange-100',
            },
          ],
        },
        about: {
          heading: 'About Webstack Builders',
          items: [
            {
              stat: '10+',
              area: 'Years Experience',
            },
            {
              stat: '100%',
              area: 'IaC &amp; CI/CD',
            },
            {
              stat: '24/7',
              area: 'Support Available',
            },
          ],
        },
        close: "Get In Touch When You're Back Online",
        retryText: 'Try again',
      }}
    />
  </div>
</PageLayout>
