---
export const prerender = true

import TagPage from '@components/Pages/TagPage/index.astro'
import {
  getAdditionalTagPageStaticPaths,
  renderTagContent,
  type TagPageProps,
} from '@lib/tags/pagination'

export interface Params {
  tag: string
  page: string
}

export async function getStaticPaths() {
  return getAdditionalTagPageStaticPaths()
}

const { tagEntry, content, currentPage } = Astro.props as TagPageProps
const { Content: TagContent } = await renderTagContent(tagEntry)
---

<TagPage tagEntry={tagEntry} content={content} currentPage={currentPage} TagContent={TagContent} />
