{% import "./partials/footer-macro.mjml" as footer %}

<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text>Hello, {{ name }}!</mj-text>
        {{ footer.renderFooter(common.company.websiteLabel, common.company.url) }}
        {% include "./partials/common-contact.mjml" %}
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>