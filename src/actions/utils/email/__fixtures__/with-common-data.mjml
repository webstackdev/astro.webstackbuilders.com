<mjml>
  <mj-body>
    <mj-section>
      <mj-column>
        <mj-text>Hello, {{ name }}!</mj-text>
        <mj-text>
          Visit <a href="{{ common.company.url }}">{{ common.company.websiteLabel }}</a>.
        </mj-text>
        <mj-text>
          Contact {{ common.company.name }} at
          <a href="{{ common.company.emailHref }}">{{ common.company.email }}</a>.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>